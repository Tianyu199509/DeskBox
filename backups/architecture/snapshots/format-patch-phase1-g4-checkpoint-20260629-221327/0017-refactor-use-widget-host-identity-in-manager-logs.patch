+    private static string FormatHostWindow(IDesktopWidgetWindow window)
+    {
+        var identity = window.Identity;
+        return $"{identity.LogDisplayName} kind={identity.WidgetKind} hwnd=0x{identity.WindowHandle.ToInt64():X}";
+    }
