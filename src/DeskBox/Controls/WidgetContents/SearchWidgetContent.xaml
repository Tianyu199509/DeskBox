<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DeskBox.Controls.WidgetContents.SearchWidgetContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:DeskBox.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Hover style for interactive items in the widget -->
        <Style x:Key="WidgetItemHoverStyle" TargetType="Grid">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Padding="12,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Bar Button -->
        <Grid Grid.Row="0" x:Name="SearchBarButton" Padding="10,8" CornerRadius="6"
              Background="{ThemeResource ControlFillColorDefaultBrush}"
              BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
              BorderThickness="1"
              PointerEntered="SearchBar_PointerEntered"
              PointerExited="SearchBar_PointerExited"
              PointerPressed="SearchBar_PointerPressed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <controls:WidgetTitleIcon x:Name="SearchIcon" Grid.Column="0"
                                      IconKind="Search" IconSize="12"
                                      VerticalAlignment="Center" Margin="0,0,8,0"/>

            <TextBlock Grid.Column="1" x:Name="PlaceholderText"
                       FontSize="12.5"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       VerticalAlignment="Center"/>

            <Border Grid.Column="2" Padding="5,2" CornerRadius="3"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    VerticalAlignment="Center">
                <TextBlock x:Name="HotkeyBadge" FontSize="10"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Border>
        </Grid>

        <!-- Scrollable content area: history + recommendations -->
        <ScrollViewer Grid.Row="1" x:Name="ContentScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto"
                      HorizontalScrollMode="Disabled"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="0,6,0,0">
            <StackPanel>
                <!-- Recent Search History -->
                <ItemsControl x:Name="HistoryList" Visibility="Collapsed">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1" Padding="6,5" CornerRadius="5"
                                  PointerEntered="HistoryItem_PointerEntered"
                                  PointerExited="HistoryItem_PointerExited"
                                  PointerPressed="HistoryItem_PointerPressed"
                                  Tag="{Binding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE81C;" FontSize="11"
                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                          VerticalAlignment="Center" Margin="2,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding}" FontSize="11.5"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Recommendation Cards -->
                <ItemsControl x:Name="RecommendationsList" Visibility="Collapsed">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1" Padding="6,5" CornerRadius="5"
                                  PointerEntered="RecItem_PointerEntered"
                                  PointerExited="RecItem_PointerExited">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="{Binding Glyph}" FontSize="11"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                          VerticalAlignment="Center" Margin="2,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="11.5"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state hint -->
                <StackPanel x:Name="EmptyStateHint"
                            Margin="8,18"
                            Visibility="Visible">
                    <FontIcon Glyph="&#xE721;" FontSize="22"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock x:Name="EmptyStateHintText"
                               FontSize="11.5"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer: clear history (compact, right-aligned). Only visible when
             there is recent search history to clear. -->
        <Grid Grid.Row="2" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="ClearHistoryButton" Grid.Column="1"
                    Padding="8,4" MinHeight="0"
                    Background="Transparent" BorderThickness="0"
                    VerticalAlignment="Center" HorizontalAlignment="Right"
                    Click="ClearHistoryButton_Click"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <FontIcon Glyph="&#xE74D;" FontSize="11"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                              VerticalAlignment="Center"/>
                    <TextBlock x:Name="ClearHistoryLabel" FontSize="11.5"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
