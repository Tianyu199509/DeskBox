<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DeskBox.Controls.WidgetContents.SearchWidgetContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:DeskBox.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Padding="12,10" PointerPressed="RootGrid_PointerPressed">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Bar -->
        <Grid Grid.Row="0" Padding="10,8" CornerRadius="6"
              Background="{ThemeResource ControlFillColorDefaultBrush}"
              BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
              BorderThickness="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <controls:WidgetTitleIcon x:Name="SearchIcon" Grid.Column="0"
                                      IconKind="Search" IconSize="12"
                                      VerticalAlignment="Center" Margin="0,0,8,0"/>

            <TextBlock Grid.Column="1" x:Name="PlaceholderText"
                       FontSize="12.5"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       VerticalAlignment="Center"/>

            <Border Grid.Column="2" Padding="5,2" CornerRadius="3"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    VerticalAlignment="Center">
                <TextBlock x:Name="HotkeyBadge" FontSize="10"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Border>
        </Grid>

        <!-- Recommendation Cards -->
        <ItemsControl Grid.Row="1" x:Name="RecommendationsList" Margin="0,8,0,0" Visibility="Collapsed">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,1" Padding="6,4" CornerRadius="5"
                          Background="{ThemeResource SubtleFillColorTransparentBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="{Binding Glyph}" FontSize="11"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                  VerticalAlignment="Center" Margin="2,0,8,0"/>
                        <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="11.5"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
