<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DeskBox.Controls.WidgetContents.MusicWidgetContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="MusicIconButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid
                            x:Name="IconButtonRoot"
                            Background="Transparent"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <VisualState.Setters>
                                            <Setter Target="IconButtonHoverSurface.Opacity" Value="0" />
                                            <Setter Target="IconButtonPressedSurface.Opacity" Value="0" />
                                            <Setter Target="IconButtonContentPresenter.Opacity" Value="0.92" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="IconButtonHoverSurface.Opacity" Value="0.16" />
                                            <Setter Target="IconButtonPressedSurface.Opacity" Value="0" />
                                            <Setter Target="IconButtonContentPresenter.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="IconButtonHoverSurface.Opacity" Value="0.10" />
                                            <Setter Target="IconButtonPressedSurface.Opacity" Value="0.24" />
                                            <Setter Target="IconButtonContentPresenter.Opacity" Value="0.82" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="IconButtonHoverSurface.Opacity" Value="0" />
                                            <Setter Target="IconButtonPressedSurface.Opacity" Value="0" />
                                            <Setter Target="IconButtonContentPresenter.Opacity" Value="0.34" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border
                                x:Name="IconButtonHoverSurface"
                                Background="{ThemeResource TextFillColorPrimaryBrush}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                IsHitTestVisible="False"
                                Opacity="0" />
                            <Border
                                x:Name="IconButtonPressedSurface"
                                Background="{ThemeResource TextFillColorPrimaryBrush}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                IsHitTestVisible="False"
                                Opacity="0" />
                            <ContentPresenter
                                x:Name="IconButtonContentPresenter"
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MusicPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{ThemeResource SystemControlHighlightAccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="21" />
            <Setter Property="Foreground" Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid
                            x:Name="PrimaryButtonRoot"
                            Background="Transparent"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <VisualState.Setters>
                                            <Setter Target="PrimarySurface.Opacity" Value="1" />
                                            <Setter Target="PrimaryHoverOverlay.Opacity" Value="0" />
                                            <Setter Target="PrimaryPressedOverlay.Opacity" Value="0" />
                                            <Setter Target="PrimaryContentPresenter.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="PrimarySurface.Opacity" Value="1" />
                                            <Setter Target="PrimaryHoverOverlay.Opacity" Value="0.10" />
                                            <Setter Target="PrimaryPressedOverlay.Opacity" Value="0" />
                                            <Setter Target="PrimaryContentPresenter.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="PrimarySurface.Opacity" Value="0.96" />
                                            <Setter Target="PrimaryHoverOverlay.Opacity" Value="0" />
                                            <Setter Target="PrimaryPressedOverlay.Opacity" Value="0.16" />
                                            <Setter Target="PrimaryContentPresenter.Opacity" Value="0.86" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="PrimarySurface.Opacity" Value="0.42" />
                                            <Setter Target="PrimaryHoverOverlay.Opacity" Value="0" />
                                            <Setter Target="PrimaryPressedOverlay.Opacity" Value="0" />
                                            <Setter Target="PrimaryContentPresenter.Opacity" Value="0.40" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border
                                x:Name="PrimarySurface"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                IsHitTestVisible="False" />
                            <Border
                                x:Name="PrimaryHoverOverlay"
                                Background="#FFFFFFFF"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                IsHitTestVisible="False"
                                Opacity="0" />
                            <Border
                                x:Name="PrimaryPressedOverlay"
                                Background="#66000000"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                IsHitTestVisible="False"
                                Opacity="0" />
                            <ContentPresenter
                                x:Name="PrimaryContentPresenter"
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid
        x:Name="RootGrid"
        Padding="0"
        PointerPressed="RootGrid_PointerPressed">
        <Border
            x:Name="ArtworkBackdrop"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            CornerRadius="{Binding ArtworkBackdropCornerRadius}"
            IsHitTestVisible="False"
            Visibility="{Binding ArtworkBackdropVisibility}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="{Binding ArtworkBackdropStartColor}" />
                    <GradientStop Offset="0.48" Color="{Binding ArtworkBackdropMidColor}" />
                    <GradientStop Offset="1" Color="{Binding ArtworkBackdropEndColor}" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Grid
            x:Name="MinimalLayout"
            Visibility="Collapsed">
            <Border
                x:Name="MinimalArtworkSurface"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid>
                    <Rectangle
                        x:Name="MinimalArtworkImage"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Visibility="{Binding ThumbnailVisibility}">
                        <Rectangle.Fill>
                            <ImageBrush
                                AlignmentX="Center"
                                AlignmentY="Center"
                                ImageSource="{Binding ThumbnailImage}"
                                Stretch="UniformToFill" />
                        </Rectangle.Fill>
                    </Rectangle>
                    <Grid Visibility="{Binding ThumbnailPlaceholderVisibility}">
                        <Rectangle Fill="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                        <FontIcon
                            FontSize="44"
                            Glyph="&#xEC4F;"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                </Grid>
            </Border>

            <Border
                x:Name="MinimalControlPanel"
                Margin="8"
                Padding="8,5"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Bottom"
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" MinWidth="0" />
                    </Grid.ColumnDefinitions>
                    <StackPanel
                        Grid.Column="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="3">
                        <Button
                            x:Name="MinimalPlayPauseButton"
                            Width="28"
                            Height="28"
                            MinWidth="28"
                            MinHeight="28"
                            Click="PlayPauseButton_Click"
                            CornerRadius="5"
                            IsEnabled="{Binding CanPlayPause}"
                            Style="{StaticResource MusicIconButtonStyle}"
                            ToolTipService.ToolTip="{Binding PlayPauseTooltip}">
                            <Grid Width="18" Height="18">
                                <Viewbox Width="18" Height="18" Visibility="{Binding PlayIconVisibility}">
                                    <Canvas Width="20" Height="20">
                                        <Path
                                            Data="M 4,2.5 C 3.4,2.13 2.9,2.55 2.9,3.3 L 2.9,16.7 C 2.9,17.45 3.4,17.87 4,17.5 L 17,10.75 C 17.75,10.32 17.75,9.68 17,9.25 Z"
                                            Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                                    </Canvas>
                                </Viewbox>
                                <Viewbox Width="18" Height="18" Visibility="{Binding PauseIconVisibility}">
                                    <Canvas Width="20" Height="20">
                                        <Border Canvas.Left="3.5" Canvas.Top="2.5" Width="4" Height="15" Background="{ThemeResource TextFillColorPrimaryBrush}" CornerRadius="0.75" />
                                        <Border Canvas.Left="12.5" Canvas.Top="2.5" Width="4" Height="15" Background="{ThemeResource TextFillColorPrimaryBrush}" CornerRadius="0.75" />
                                    </Canvas>
                                </Viewbox>
                            </Grid>
                        </Button>
                        <Button
                            x:Name="MinimalNextButton"
                            Width="28"
                            Height="28"
                            MinWidth="28"
                            MinHeight="28"
                            Click="NextButton_Click"
                            CornerRadius="5"
                            IsEnabled="{Binding CanGoNext}"
                            Style="{StaticResource MusicIconButtonStyle}"
                            ToolTipService.ToolTip="{Binding NextTooltip}">
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="20" Height="20">
                                    <Path
                                        Data="M 3.5,2.8 C 2.95,2.46 2.55,2.84 2.55,3.52 L 2.55,16.48 C 2.55,17.16 2.95,17.54 3.5,17.2 L 13.2,10.7 C 13.9,10.28 13.9,9.72 13.2,9.3 Z"
                                        Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                                    <Border
                                        Canvas.Left="16.2"
                                        Canvas.Top="2.5"
                                        Width="2.4"
                                        Height="15"
                                        Background="{ThemeResource TextFillColorPrimaryBrush}"
                                        CornerRadius="1.2" />
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                    <Grid
                        x:Name="MinimalTitleMarqueeHost"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        MinWidth="0"
                        SizeChanged="TitleMarqueeHost_SizeChanged"
                        ToolTipService.ToolTip="{Binding Title}">
                        <Grid.Clip>
                            <RectangleGeometry x:Name="MinimalTitleMarqueeClip" />
                        </Grid.Clip>
                        <TextBlock
                            x:Name="MinimalTitleStaticText"
                            VerticalAlignment="Center"
                            FontSize="{Binding MinimalTitleTextSize}"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                            MaxLines="1"
                            MinWidth="0"
                            Text="{Binding Title}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />
                        <Canvas
                            x:Name="MinimalTitleMarqueeCanvas"
                            Height="{Binding ActualHeight, ElementName=MinimalTitleStaticText}"
                            IsHitTestVisible="False"
                            Visibility="Collapsed">
                            <TextBlock
                                x:Name="MinimalTitleTextPrimary"
                                FontSize="{Binding MinimalTitleTextSize}"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                MaxLines="1"
                                Text="{Binding Title}"
                                TextTrimming="Clip"
                                TextWrapping="NoWrap" />
                            <TextBlock
                                x:Name="MinimalTitleTextClone"
                                FontSize="{Binding MinimalTitleTextSize}"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                MaxLines="1"
                                Text="{Binding Title}"
                                TextTrimming="Clip"
                                TextWrapping="NoWrap" />
                        </Canvas>
                        <Canvas
                            Width="0"
                            Height="0"
                            IsHitTestVisible="False"
                            Opacity="0">
                            <TextBlock
                                x:Name="MinimalTitleMeasureText"
                                FontSize="{Binding MinimalTitleTextSize}"
                                FontWeight="SemiBold"
                                MaxLines="1"
                                Text="{Binding Title}"
                                TextTrimming="Clip"
                                TextWrapping="NoWrap" />
                        </Canvas>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid
            x:Name="ContentGrid"
            Padding="12,12,12,11"
            ColumnSpacing="12"
            RowSpacing="8"
            VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="AlbumColumn" Width="82" />
                <ColumnDefinition Width="*" MinWidth="0" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="TopRow" Height="82" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                x:Name="AlbumArtShadow"
                Grid.Row="0"
                Grid.Column="0"
                Width="82"
                Height="82"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="#66000000"
                CornerRadius="12"
                Opacity="0.18"
                Translation="0,2,0" />

            <Border
                x:Name="AlbumArtSurface"
                Grid.Row="0"
                Grid.Column="0"
                Width="82"
                Height="82"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                PointerEntered="AlbumArtSurface_PointerEntered"
                PointerExited="AlbumArtSurface_PointerExited"
                PointerMoved="AlbumArtSurface_PointerMoved"
                SizeChanged="AlbumArtSurface_SizeChanged">
                <Grid>
                    <Image
                        x:Name="AlbumArtworkImage"
                        Source="{Binding ThumbnailImage}"
                        Stretch="UniformToFill"
                        Visibility="{Binding ThumbnailVisibility}" />
                    <Border
                        IsHitTestVisible="False"
                        Opacity="0.34">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#66FFFFFF" />
                                <GradientStop Offset="0.42" Color="#12FFFFFF" />
                                <GradientStop Offset="1" Color="#33000000" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border
                        Margin="1"
                        BorderBrush="#24FFFFFF"
                        BorderThickness="1"
                        CornerRadius="11"
                        IsHitTestVisible="False"
                        x:Name="AlbumArtInnerBorder" />
                    <Grid Visibility="{Binding ThumbnailPlaceholderVisibility}">
                        <Border
                            x:Name="AlbumArtPlaceholderBackground"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="12" />
                        <FontIcon
                            FontSize="30"
                            Glyph="&#xEC4F;"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                </Grid>
            </Border>

            <Grid
                x:Name="TrackInfoGrid"
                Grid.Row="0"
                Grid.Column="1"
                MinWidth="0"
                RowSpacing="4"
                VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid
                    x:Name="TitleMarqueeHost"
                    Grid.Row="0"
                    MinWidth="0"
                    SizeChanged="TitleMarqueeHost_SizeChanged">
                    <Grid.Clip>
                        <RectangleGeometry x:Name="TitleMarqueeClip" />
                    </Grid.Clip>
                    <TextBlock
                        x:Name="TitleStaticText"
                        FontSize="{Binding TitleTextSize}"
                        FontWeight="SemiBold"
                        MaxLines="1"
                        MinWidth="0"
                        Text="{Binding Title}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                    <Canvas
                        x:Name="TitleMarqueeCanvas"
                        Height="{Binding ActualHeight, ElementName=TitleStaticText}"
                        IsHitTestVisible="False"
                        Visibility="Collapsed">
                        <TextBlock
                            x:Name="TitleTextPrimary"
                            FontSize="{Binding TitleTextSize}"
                            FontWeight="SemiBold"
                            MaxLines="1"
                            Text="{Binding Title}"
                            TextTrimming="Clip"
                            TextWrapping="NoWrap" />
                        <TextBlock
                            x:Name="TitleTextClone"
                            FontSize="{Binding TitleTextSize}"
                            FontWeight="SemiBold"
                            MaxLines="1"
                            Text="{Binding Title}"
                            TextTrimming="Clip"
                            TextWrapping="NoWrap" />
                    </Canvas>
                    <Canvas
                        Width="0"
                        Height="0"
                        IsHitTestVisible="False"
                        Opacity="0">
                        <TextBlock
                            x:Name="TitleMeasureText"
                            FontSize="{Binding TitleTextSize}"
                            FontWeight="SemiBold"
                            MaxLines="1"
                            Text="{Binding Title}"
                            TextTrimming="Clip"
                            TextWrapping="NoWrap" />
                    </Canvas>
                </Grid>

                <TextBlock
                    Grid.Row="1"
                    FontSize="{Binding SecondaryTextSize}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    MaxLines="1"
                    MinWidth="0"
                    Text="{Binding Artist}"
                    TextTrimming="CharacterEllipsis" />

                <TextBlock
                    Grid.Row="2"
                    FontSize="{Binding CaptionTextSize}"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    MaxLines="1"
                    MinWidth="0"
                    Text="{Binding StatusText}"
                    TextTrimming="CharacterEllipsis" />
            </Grid>

            <Grid
                x:Name="ProgressRow"
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,3,0,0"
                ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="PositionColumn" Width="34" />
                    <ColumnDefinition Width="*" MinWidth="0" />
                    <ColumnDefinition x:Name="DurationColumn" Width="34" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="{Binding CaptionTextSize}"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{Binding PositionText}"
                    TextAlignment="Left" />

                <Grid
                    x:Name="ProgressHost"
                    Grid.Column="1"
                    Height="24"
                    MinWidth="44"
                    Background="Transparent"
                    HorizontalAlignment="Stretch"
                    PointerEntered="ProgressHost_PointerEntered"
                    PointerExited="ProgressHost_PointerExited"
                    PointerMoved="ProgressHost_PointerMoved"
                    PointerPressed="ProgressHost_PointerPressed"
                    PointerReleased="ProgressHost_PointerReleased">
                    <Border
                        x:Name="ProgressTrack"
                        Height="4"
                        VerticalAlignment="Center"
                        Background="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
                        CornerRadius="2"
                        Opacity="0.36" />
                    <Border
                        x:Name="ProgressFill"
                        Height="4"
                        Width="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="{Binding MusicAccentBrush}"
                        CornerRadius="2" />
                    <Ellipse
                        x:Name="ProgressThumb"
                        Width="10"
                        Height="10"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Fill="{Binding MusicAccentBrush}"
                        Opacity="0"
                        Translation="-5,0,0" />
                </Grid>

                <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    FontSize="{Binding CaptionTextSize}"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{Binding DurationText}"
                    TextAlignment="Right" />
            </Grid>

            <StackPanel
                x:Name="ControlsPanel"
                Grid.Row="2"
                Grid.ColumnSpan="2"
                Margin="0,5,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="12"
                VerticalAlignment="Bottom">
                <Button
                    x:Name="PlaybackModeButton"
                    Click="PlaybackModeButton_Click"
                    IsEnabled="{Binding CanChangePlaybackMode}"
                    Opacity="{Binding PlaybackModeOpacity}"
                    Style="{StaticResource MusicIconButtonStyle}"
                    ToolTipService.ToolTip="{Binding PlaybackModeTooltip}">
                    <FontIcon FontSize="14" Glyph="{Binding PlaybackModeGlyph}" />
                </Button>

                <Button
                    x:Name="PreviousButton"
                    Click="PreviousButton_Click"
                    IsEnabled="{Binding CanGoPrevious}"
                    Style="{StaticResource MusicIconButtonStyle}"
                    ToolTipService.ToolTip="{Binding PreviousTooltip}">
                    <Viewbox Width="20" Height="20">
                        <Canvas Width="20" Height="20">
                            <Border Canvas.Left="1.4" Canvas.Top="2.5" Width="2.4" Height="15" Background="{ThemeResource TextFillColorPrimaryBrush}" CornerRadius="1.2" />
                            <Path Data="M 16.5,2.8 C 17.05,2.46 17.45,2.84 17.45,3.52 L 17.45,16.48 C 17.45,17.16 17.05,17.54 16.5,17.2 L 6.8,10.7 C 6.1,10.28 6.1,9.72 6.8,9.3 Z" Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button
                    x:Name="PlayPauseButton"
                    Click="PlayPauseButton_Click"
                    IsEnabled="{Binding CanPlayPause}"
                    Style="{StaticResource MusicIconButtonStyle}"
                    ToolTipService.ToolTip="{Binding PlayPauseTooltip}">
                    <Grid Width="20" Height="20">
                        <Viewbox Width="20" Height="20" Visibility="{Binding PlayIconVisibility}">
                            <Canvas Width="20" Height="20">
                                <Path Data="M 4,2.5 C 3.4,2.13 2.9,2.55 2.9,3.3 L 2.9,16.7 C 2.9,17.45 3.4,17.87 4,17.5 L 17,10.75 C 17.75,10.32 17.75,9.68 17,9.25 Z" Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                            </Canvas>
                        </Viewbox>
                        <Viewbox Width="20" Height="20" Visibility="{Binding PauseIconVisibility}">
                            <Canvas Width="20" Height="20">
                                <Border Canvas.Left="3.5" Canvas.Top="2.5" Width="4" Height="15" Background="{ThemeResource TextFillColorPrimaryBrush}" CornerRadius="0.75" />
                                <Border Canvas.Left="12.5" Canvas.Top="2.5" Width="4" Height="15" Background="{ThemeResource TextFillColorPrimaryBrush}" CornerRadius="0.75" />
                            </Canvas>
                        </Viewbox>
                    </Grid>
                </Button>

                <Button
                    x:Name="NextButton"
                    Click="NextButton_Click"
                    IsEnabled="{Binding CanGoNext}"
                    Style="{StaticResource MusicIconButtonStyle}"
                    ToolTipService.ToolTip="{Binding NextTooltip}">
                    <Viewbox Width="20" Height="20">
                        <Canvas Width="20" Height="20">
                            <Path Data="M 3.5,2.8 C 2.95,2.46 2.55,2.84 2.55,3.52 L 2.55,16.48 C 2.55,17.16 2.95,17.54 3.5,17.2 L 13.2,10.7 C 13.9,10.28 13.9,9.72 13.2,9.3 Z" Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                            <Border Canvas.Left="16.2" Canvas.Top="2.5" Width="2.4" Height="15" Background="{ThemeResource TextFillColorPrimaryBrush}" CornerRadius="1.2" />
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button
                    x:Name="VolumeButton"
                    Click="VolumeButton_Click"
                    Style="{StaticResource MusicIconButtonStyle}"
                    ToolTipService.ToolTip="{Binding VolumeTooltip}">
                    <FontIcon FontSize="15" Glyph="&#xE767;" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Record mode: centered rotating vinyl + track info below. -->
        <Grid
            x:Name="RecordLayout"
            Padding="12"
            RowSpacing="6"
            VerticalAlignment="Center"
            Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid
                x:Name="RecordVinylHost"
                Grid.Row="0"
                Width="160"
                Height="160"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <RotateTransform x:Name="RecordVinylRotateTransform" Angle="0" />
                </Grid.RenderTransform>
                <!-- Fixed 160x160 coordinate space, scaled by Viewbox to the host size. -->
                <Viewbox>
                    <Grid Width="160" Height="160">
                        <!-- warm outer rim glow -->
                        <Ellipse Fill="#40000000" Opacity="0.32" Margin="-1,5,-1,-1" />
                        <!-- disc body -->
                        <Ellipse Fill="#080808" />
                        <!-- dense concentric grooves -->
                        <Ellipse Stroke="#1A1A1A" StrokeThickness="0.7" Margin="3" />
                        <Ellipse Stroke="#222222" StrokeThickness="0.6" Margin="6" />
                        <Ellipse Stroke="#1B1B1B" StrokeThickness="0.5" Margin="9" />
                        <Ellipse Stroke="#262626" StrokeThickness="0.5" Margin="13" />
                        <Ellipse Stroke="#1D1D1D" StrokeThickness="0.45" Margin="17" />
                        <Ellipse Stroke="#242424" StrokeThickness="0.4" Margin="21" />
                        <Ellipse Stroke="#1A1A1A" StrokeThickness="0.4" Margin="25" />
                        <Ellipse Stroke="#222222" StrokeThickness="0.35" Margin="30" />
                        <Ellipse Stroke="#1B1B1B" StrokeThickness="0.35" Margin="35" />
                        <!-- subtle highlight sheen -->
                        <Ellipse>
                            <Ellipse.Fill>
                                <RadialGradientBrush GradientOrigin="0.30,0.24" Center="0.5,0.5" RadiusX="0.55" RadiusY="0.55">
                                    <GradientStop Offset="0" Color="#70FFFFFF" />
                                    <GradientStop Offset="0.35" Color="#10FFFFFF" />
                                    <GradientStop Offset="1" Color="#00000000" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <!-- center label ring -->
                        <Ellipse Stroke="#000000" StrokeThickness="1" Margin="31" />
                        <!-- center label = album cover (large) -->
                        <Ellipse x:Name="RecordVinylLabel" Margin="32">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="{Binding ThumbnailImage}" Stretch="UniformToFill" />
                            </Ellipse.Fill>
                        </Ellipse>
                        <!-- spindle -->
                        <Ellipse Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center" Stroke="#50000000" StrokeThickness="0.8">
                            <Ellipse.Fill>
                                <RadialGradientBrush GradientOrigin="0.32,0.28" Center="0.5,0.5" RadiusX="0.62" RadiusY="0.62">
                                    <GradientStop Offset="0" Color="#FFF3F3F6" />
                                    <GradientStop Offset="0.7" Color="#FFB6B6BE" />
                                    <GradientStop Offset="1" Color="#FF7E7E86" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Width="3" Height="3" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="#CC1A1A1E" />
                    </Grid>
                </Viewbox>
            </Grid>

            <!-- Tonearm overlaid on the vinyl (rotates between play/pause) -->
            <Grid
                x:Name="RecordTonearm"
                Grid.Row="0"
                Width="67"
                Height="80"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="115,-48,0,0">
                <!-- Fixed 100x120 design space; pivot at (50,20), scaled with the disc from code. -->
                <Viewbox Stretch="Uniform">
                    <Grid Width="100" Height="120">
                        <!-- counterweight stem + weight (behind the pivot) -->
                        <Line
                            X1="50" Y1="20" X2="57" Y2="7"
                            Stroke="#9A9AA2"
                            StrokeThickness="2.6"
                            StrokeStartLineCap="Round"
                            StrokeEndLineCap="Round" />
                        <Ellipse
                            Width="12" Height="12"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="51,1,0,0"
                            Stroke="#55555D"
                            StrokeThickness="0.6">
                            <Ellipse.Fill>
                                <RadialGradientBrush GradientOrigin="0.32,0.28" Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
                                    <GradientStop Offset="0" Color="#FFEDEDF1" />
                                    <GradientStop Offset="0.65" Color="#FF9C9CA4" />
                                    <GradientStop Offset="1" Color="#FF6F6F77" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <!-- arm tube with highlight -->
                        <Path
                            Data="M 50,20 C 45,46 39,70 33,92"
                            Stroke="#D4D4DA"
                            StrokeThickness="3.2"
                            StrokeStartLineCap="Round"
                            StrokeEndLineCap="Round" />
                        <Path
                            Data="M 49.2,20 C 44.2,46 38.2,70 32.2,92"
                            Stroke="#FFFFFF"
                            StrokeThickness="0.8"
                            Opacity="0.55"
                            StrokeStartLineCap="Round"
                            StrokeEndLineCap="Round" />
                        <!-- pivot bearing -->
                        <Ellipse
                            Width="17" Height="17"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="41.5,11.5,0,0"
                            Stroke="#66666E"
                            StrokeThickness="0.6">
                            <Ellipse.Fill>
                                <RadialGradientBrush GradientOrigin="0.32,0.28" Center="0.5,0.5" RadiusX="0.62" RadiusY="0.62">
                                    <GradientStop Offset="0" Color="#FFF6F6F9" />
                                    <GradientStop Offset="0.6" Color="#FFC4C4CC" />
                                    <GradientStop Offset="1" Color="#FF8F8F97" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse
                            Width="6" Height="6"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="47,17,0,0"
                            Fill="#5A5A62" />
                        <!-- headshell (tilted to follow the arm) -->
                        <Border
                            Width="9" Height="17"
                            CornerRadius="4"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="28.5,90,0,0"
                            BorderBrush="#70707A"
                            BorderThickness="0.6"
                            RenderTransformOrigin="0.5,0.1">
                            <Border.RenderTransform>
                                <RotateTransform Angle="-15" />
                            </Border.RenderTransform>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0" Color="#FFEDEDF1" />
                                    <GradientStop Offset="1" Color="#FFBEBEC6" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- stylus -->
                        <Line
                            X1="31" Y1="106" X2="27.5" Y2="111"
                            Stroke="#55555D"
                            StrokeThickness="1.3"
                            StrokeEndLineCap="Round" />
                    </Grid>
                </Viewbox>
            </Grid>

            <StackPanel
                Grid.Row="1"
                HorizontalAlignment="Center"
                Spacing="1"
                Margin="0,4,0,0">
                <TextBlock
                    x:Name="RecordTitleText"
                    MaxLines="1"
                    HorizontalAlignment="Center"
                    FontSize="17"
                    FontWeight="SemiBold"
                    Text="{Binding Title}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    x:Name="RecordArtistText"
                    MaxLines="1"
                    HorizontalAlignment="Center"
                    FontSize="13"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding Artist}"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <Grid
                Grid.Row="2"
                Margin="0,2,0,0"
                HorizontalAlignment="Stretch"
                MaxWidth="280"
                ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{Binding PositionText}" />
                <Grid
                    x:Name="RecordProgressHost"
                    Grid.Column="1"
                    Height="4"
                    MinWidth="80"
                    VerticalAlignment="Center">
                    <Border
                        x:Name="RecordProgressTrack"
                        Height="4"
                        Background="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
                        CornerRadius="2"
                        Opacity="0.36" />
                    <Border
                        x:Name="RecordProgressFill"
                        Height="4"
                        Width="0"
                        HorizontalAlignment="Left"
                        Background="{Binding MusicAccentBrush}"
                        CornerRadius="2" />
                </Grid>
                <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{Binding DurationText}" />
            </Grid>

            <StackPanel
                x:Name="RecordControlsPanel"
                Grid.Row="3"
                Margin="0,4,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="10">
                <Button
                    x:Name="RecordPlaybackModeButton"
                    Click="PlaybackModeButton_Click"
                    IsEnabled="{Binding CanChangePlaybackMode}"
                    Opacity="{Binding PlaybackModeOpacity}"
                    Style="{StaticResource MusicIconButtonStyle}"
                    ToolTipService.ToolTip="{Binding PlaybackModeTooltip}">
                    <FontIcon FontSize="14" Glyph="{Binding PlaybackModeGlyph}" />
                </Button>
                <Button
                    x:Name="RecordPreviousButton"
                    Click="PreviousButton_Click"
                    IsEnabled="{Binding CanGoPrevious}"
                    Style="{StaticResource MusicIconButtonStyle}"
                    ToolTipService.ToolTip="{Binding PreviousTooltip}">
                    <Viewbox Width="20" Height="20">
                        <Canvas Width="20" Height="20">
                            <Border Canvas.Left="1.4" Canvas.Top="2.5" Width="2.4" Height="15" Background="{ThemeResource TextFillColorPrimaryBrush}" CornerRadius="1.2" />
                            <Path Data="M 16.5,2.8 C 17.05,2.46 17.45,2.84 17.45,3.52 L 17.45,16.48 C 17.45,17.16 17.05,17.54 16.5,17.2 L 6.8,10.7 C 6.1,10.28 6.1,9.72 6.8,9.3 Z" Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button
                    x:Name="RecordPlayPauseButton"
                    Click="PlayPauseButton_Click"
                    IsEnabled="{Binding CanPlayPause}"
                    Style="{StaticResource MusicIconButtonStyle}"
                    ToolTipService.ToolTip="{Binding PlayPauseTooltip}">
                    <Grid Width="20" Height="20">
                        <Viewbox Width="20" Height="20" Visibility="{Binding PlayIconVisibility}">
                            <Canvas Width="20" Height="20">
                                <Path Data="M 4,2.5 C 3.4,2.13 2.9,2.55 2.9,3.3 L 2.9,16.7 C 2.9,17.45 3.4,17.87 4,17.5 L 17,10.75 C 17.75,10.32 17.75,9.68 17,9.25 Z" Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                            </Canvas>
                        </Viewbox>
                        <Viewbox Width="20" Height="20" Visibility="{Binding PauseIconVisibility}">
                            <Canvas Width="20" Height="20">
                                <Border Canvas.Left="3.5" Canvas.Top="2.5" Width="4" Height="15" Background="{ThemeResource TextFillColorPrimaryBrush}" CornerRadius="0.75" />
                                <Border Canvas.Left="12.5" Canvas.Top="2.5" Width="4" Height="15" Background="{ThemeResource TextFillColorPrimaryBrush}" CornerRadius="0.75" />
                            </Canvas>
                        </Viewbox>
                    </Grid>
                </Button>
                <Button
                    x:Name="RecordNextButton"
                    Click="NextButton_Click"
                    IsEnabled="{Binding CanGoNext}"
                    Style="{StaticResource MusicIconButtonStyle}"
                    ToolTipService.ToolTip="{Binding NextTooltip}">
                    <Viewbox Width="20" Height="20">
                        <Canvas Width="20" Height="20">
                            <Path Data="M 3.5,2.8 C 2.95,2.46 2.55,2.84 2.55,3.52 L 2.55,16.48 C 2.55,17.16 2.95,17.54 3.5,17.2 L 13.2,10.7 C 13.9,10.28 13.9,9.72 13.2,9.3 Z" Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                            <Border Canvas.Left="16.2" Canvas.Top="2.5" Width="2.4" Height="15" Background="{ThemeResource TextFillColorPrimaryBrush}" CornerRadius="1.2" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button
                    x:Name="RecordVolumeButton"
                    Click="VolumeButton_Click"
                    Style="{StaticResource MusicIconButtonStyle}"
                    ToolTipService.ToolTip="{Binding VolumeTooltip}">
                    <FontIcon FontSize="15" Glyph="&#xE767;" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Record mode: Horizontal - vinyl left, info right. -->
        <Grid
            x:Name="RecordHorizontalLayout"
            Padding="12"
            ColumnSpacing="12"
            VerticalAlignment="Center"
            Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="0" />
            </Grid.ColumnDefinitions>

            <!-- Vinyl (left) -->
            <Grid
                x:Name="RecordHorizontalVinylHost"
                Grid.Column="0"
                Width="110"
                Height="110"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <RotateTransform x:Name="RecordHorizontalVinylRotateTransform" Angle="0" />
                </Grid.RenderTransform>
                <Viewbox>
                    <Grid Width="160" Height="160">
                        <Ellipse Fill="#40000000" Opacity="0.32" Margin="-1,5,-1,-1" />
                        <Ellipse Fill="#080808" />
                        <Ellipse Stroke="#1A1A1A" StrokeThickness="0.7" Margin="3" />
                        <Ellipse Stroke="#222222" StrokeThickness="0.6" Margin="6" />
                        <Ellipse Stroke="#1B1B1B" StrokeThickness="0.5" Margin="9" />
                        <Ellipse Stroke="#262626" StrokeThickness="0.5" Margin="13" />
                        <Ellipse Stroke="#1D1D1D" StrokeThickness="0.45" Margin="17" />
                        <Ellipse Stroke="#242424" StrokeThickness="0.4" Margin="21" />
                        <Ellipse Stroke="#1A1A1A" StrokeThickness="0.4" Margin="25" />
                        <Ellipse Stroke="#222222" StrokeThickness="0.35" Margin="30" />
                        <Ellipse Stroke="#1B1B1B" StrokeThickness="0.35" Margin="35" />
                        <Ellipse>
                            <Ellipse.Fill>
                                <RadialGradientBrush GradientOrigin="0.30,0.24" Center="0.5,0.5" RadiusX="0.55" RadiusY="0.55">
                                    <GradientStop Offset="0" Color="#70FFFFFF" />
                                    <GradientStop Offset="0.35" Color="#10FFFFFF" />
                                    <GradientStop Offset="1" Color="#00000000" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Stroke="#000000" StrokeThickness="1" Margin="31" />
                        <Ellipse x:Name="RecordHorizontalVinylLabel" Margin="32">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="{Binding ThumbnailImage}" Stretch="UniformToFill" />
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center" Stroke="#50000000" StrokeThickness="0.8">
                            <Ellipse.Fill>
                                <RadialGradientBrush GradientOrigin="0.32,0.28" Center="0.5,0.5" RadiusX="0.62" RadiusY="0.62">
                                    <GradientStop Offset="0" Color="#FFF3F3F6" />
                                    <GradientStop Offset="0.7" Color="#FFB6B6BE" />
                                    <GradientStop Offset="1" Color="#FF7E7E86" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Width="3" Height="3" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="#CC1A1A1E" />
                    </Grid>
                </Viewbox>
            </Grid>

            <!-- Info (right) -->
            <Grid Grid.Column="1" RowSpacing="6" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Spacing="1">
                    <TextBlock
                        x:Name="RecordHorizontalTitleText"
                        MaxLines="1"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Text="{Binding Title}"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        x:Name="RecordHorizontalArtistText"
                        MaxLines="1"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding Artist}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <Grid Grid.Row="1" Margin="0,2,0,0" ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Text="{Binding PositionText}" />
                    <Grid
                        x:Name="RecordHorizontalProgressHost"
                        Grid.Column="1"
                        Height="4"
                        MinWidth="60"
                        VerticalAlignment="Center">
                        <Border
                            x:Name="RecordHorizontalProgressTrack"
                            Height="4"
                            Background="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
                            CornerRadius="2"
                            Opacity="0.36" />
                        <Border
                            x:Name="RecordHorizontalProgressFill"
                            Height="4"
                            Width="0"
                            HorizontalAlignment="Left"
                            Background="{Binding MusicAccentBrush}"
                            CornerRadius="2" />
                    </Grid>
                    <TextBlock
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Text="{Binding DurationText}" />
                </Grid>
                <StackPanel
                    x:Name="RecordHorizontalControlsPanel"
                    Grid.Row="2"
                    Margin="0,2,0,0"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        x:Name="RecordHorizontalPlaybackModeButton"
                        Click="PlaybackModeButton_Click"
                        IsEnabled="{Binding CanChangePlaybackMode}"
                        Opacity="{Binding PlaybackModeOpacity}"
                        Style="{StaticResource MusicIconButtonStyle}"
                        ToolTipService.ToolTip="{Binding PlaybackModeTooltip}">
                        <FontIcon FontSize="14" Glyph="{Binding PlaybackModeGlyph}" />
                    </Button>
                    <Button
                        x:Name="RecordHorizontalPreviousButton"
                        Click="PreviousButton_Click"
                        IsEnabled="{Binding CanGoPrevious}"
                        Style="{StaticResource MusicIconButtonStyle}"
                        ToolTipService.ToolTip="{Binding PreviousTooltip}">
                        <Viewbox Width="20" Height="20">
                            <Canvas Width="20" Height="20">
                                <Border Canvas.Left="1.4" Canvas.Top="2.5" Width="2.4" Height="15" Background="{ThemeResource TextFillColorPrimaryBrush}" CornerRadius="1.2" />
                                <Path Data="M 16.5,2.8 C 17.05,2.46 17.45,2.84 17.45,3.52 L 17.45,16.48 C 17.45,17.16 17.05,17.54 16.5,17.2 L 6.8,10.7 C 6.1,10.28 6.1,9.72 6.8,9.3 Z" Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button
                        x:Name="RecordHorizontalPlayPauseButton"
                        Click="PlayPauseButton_Click"
                        IsEnabled="{Binding CanPlayPause}"
                        Style="{StaticResource MusicIconButtonStyle}"
                        ToolTipService.ToolTip="{Binding PlayPauseTooltip}">
                        <Grid Width="20" Height="20">
                            <Viewbox Width="20" Height="20" Visibility="{Binding PlayIconVisibility}">
                                <Canvas Width="20" Height="20">
                                    <Path Data="M 4,2.5 C 3.4,2.13 2.9,2.55 2.9,3.3 L 2.9,16.7 C 2.9,17.45 3.4,17.87 4,17.5 L 17,10.75 C 17.75,10.32 17.75,9.68 17,9.25 Z" Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Canvas>
                            </Viewbox>
                            <Viewbox Width="20" Height="20" Visibility="{Binding PauseIconVisibility}">
                                <Canvas Width="20" Height="20">
                                    <Border Canvas.Left="3.5" Canvas.Top="2.5" Width="4" Height="15" Background="{ThemeResource TextFillColorPrimaryBrush}" CornerRadius="0.75" />
                                    <Border Canvas.Left="12.5" Canvas.Top="2.5" Width="4" Height="15" Background="{ThemeResource TextFillColorPrimaryBrush}" CornerRadius="0.75" />
                                </Canvas>
                            </Viewbox>
                        </Grid>
                    </Button>
                    <Button
                        x:Name="RecordHorizontalNextButton"
                        Click="NextButton_Click"
                        IsEnabled="{Binding CanGoNext}"
                        Style="{StaticResource MusicIconButtonStyle}"
                        ToolTipService.ToolTip="{Binding NextTooltip}">
                        <Viewbox Width="20" Height="20">
                            <Canvas Width="20" Height="20">
                                <Path Data="M 3.5,2.8 C 2.95,2.46 2.55,2.84 2.55,3.52 L 2.55,16.48 C 2.55,17.16 2.95,17.54 3.5,17.2 L 13.2,10.7 C 13.9,10.28 13.9,9.72 13.2,9.3 Z" Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                                <Border Canvas.Left="16.2" Canvas.Top="2.5" Width="2.4" Height="15" Background="{ThemeResource TextFillColorPrimaryBrush}" CornerRadius="1.2" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button
                        x:Name="RecordHorizontalVolumeButton"
                        Click="VolumeButton_Click"
                        Style="{StaticResource MusicIconButtonStyle}"
                        ToolTipService.ToolTip="{Binding VolumeTooltip}">
                        <FontIcon FontSize="15" Glyph="&#xE767;" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <Border
            x:Name="InlineVolumePanel"
            Width="238"
            Height="48"
            Padding="10,8"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            PointerPressed="InlineVolumePanel_PointerPressed"
            Visibility="Collapsed">
            <Grid ColumnSpacing="9">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{Binding VolumeTextSize}"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    Text="{Binding SystemVolumeText}"
                    TextAlignment="Center" />

                <Slider
                    x:Name="InlineSystemVolumeSlider"
                    Grid.Column="1"
                    Height="28"
                    Margin="0,-4,0,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    IsThumbToolTipEnabled="False"
                    LargeChange="0.1"
                    Maximum="1"
                    Minimum="0"
                    Orientation="Horizontal"
                    SmallChange="0.01"
                    StepFrequency="0.01"
                    Value="{Binding SystemVolume, Mode=TwoWay}"
                    ValueChanged="InlineSystemVolumeSlider_ValueChanged" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
