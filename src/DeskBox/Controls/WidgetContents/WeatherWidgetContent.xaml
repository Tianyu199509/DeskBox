<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DeskBox.Controls.WidgetContents.WeatherWidgetContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:DeskBox.Controls.WidgetContents"
    mc:Ignorable="d"
    SizeChanged="UserControl_SizeChanged">

    <UserControl.Resources>
        <Style x:Key="WeatherIconButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- Detail chip: borderless inline tag (kept for backward compat) -->
        <Style x:Key="WeatherChipStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <!-- Hourly card background converter (borderless translucent style) -->
        <local:CurrentHourBackgroundConverter x:Key="CurrentHourBackgroundConverter" />
        <local:BoolToVisibilityConverter x:Key="IsCurrentHourVisibility" />
        <local:BoolToVisibilityConverter x:Key="NotCurrentHourVisibility" Invert="True" />

        <!-- Temperature range bar converter -->
        <local:TempBarMarginConverter x:Key="TempBarMarginConverter" BarWidth="80" />
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Padding="0">

        <!-- ─── Rich Skin Backdrop (condition based gradient) ─── -->
        <Border
            x:Name="RichBackdrop"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            CornerRadius="8"
            IsHitTestVisible="False"
            Visibility="{Binding RichSkinVisibility}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop x:Name="RichBackdropTop" Offset="0" Color="{Binding RichBackdropTopColor}" />
                    <GradientStop x:Name="RichBackdropBottom" Offset="1" Color="{Binding RichBackdropBottomColor}" />
                </LinearGradientBrush>
            </Border.Background>
            <!-- Subtle top highlight for glass depth -->
            <Border
                x:Name="RichGlossOverlay"
                VerticalAlignment="Top"
                Height="60"
                CornerRadius="8,8,0,0"
                IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0" Color="#18FFFFFF" />
                        <GradientStop Offset="1" Color="Transparent" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Border>

        <!-- ─── Rain Animation Layer ─── -->
        <Canvas
            x:Name="RainAnimationCanvas"
            IsHitTestVisible="False"
            Visibility="{Binding RainAnimationVisibility}" />

        <!-- ─── Snow Animation Layer ─── -->
        <Canvas
            x:Name="SnowAnimationCanvas"
            IsHitTestVisible="False"
            Visibility="{Binding SnowAnimationVisibility}" />

        <!-- ─── Thunder Flash Layer ─── -->
        <Border
            x:Name="ThunderFlash"
            IsHitTestVisible="False"
            Visibility="{Binding ThunderAnimationVisibility}"
            CornerRadius="8">
            <Border.Background>
                <SolidColorBrush x:Name="ThunderFlashBrush" Color="Transparent" />
            </Border.Background>
        </Border>

        <!-- ─── Clear Sky Shimmer ─── -->
        <Canvas
            x:Name="ClearShimmerCanvas"
            IsHitTestVisible="False"
            Visibility="{Binding ClearAnimationVisibility}" />

        <!-- ─── Mini Layout (compact, single-column centered) ─── -->
        <Grid
            x:Name="MiniLayout"
            Padding="8,6"
            RowSpacing="2"
            Visibility="{Binding MiniLayoutVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top: Location + refresh -->
            <Grid Grid.Row="0" ColumnSpacing="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    FontSize="{Binding CaptionTextSize}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding LocationDisplay}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap"
                    VerticalAlignment="Center"
                    Visibility="{Binding MiniLocationVisibility}" />
                <Button
                    Grid.Column="1"
                    Click="RefreshButton_Click"
                    Style="{StaticResource WeatherIconButtonStyle}"
                    Width="20"
                    Height="20"
                    MinWidth="20"
                    MinHeight="20"
                    ToolTipService.ToolTip="{Binding RefreshTooltip}">
                    <FontIcon FontSize="10" Glyph="&#xE72C;" />
                </Button>
            </Grid>

            <!-- Center: icon + temperature + description -->
            <StackPanel
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="6">
                <TextBlock
                    FontSize="{Binding CurrentEmojiSize}"
                    Text="{Binding CurrentEmoji}"
                    VerticalAlignment="Center" />
                <TextBlock
                    FontSize="{Binding TemperatureTextSize}"
                    FontWeight="SemiBold"
                    Text="{Binding CurrentTemperatureText}"
                    VerticalAlignment="Center" />
            </StackPanel>

            <TextBlock
                Grid.Row="2"
                HorizontalAlignment="Center"
                FontSize="{Binding CaptionTextSize}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{Binding CurrentDescription}"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap"
                Visibility="{Binding MiniDescriptionVisibility}" />

            <StackPanel
                Grid.Row="3"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="6">
                <TextBlock
                    FontSize="9"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{Binding MiniHumidityText}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap"
                    Visibility="{Binding MiniHumidityVisibility}" />
                <TextBlock
                    FontSize="9"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{Binding MiniWindText}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap"
                    Visibility="{Binding MiniWindVisibility}" />
                <TextBlock
                    FontSize="9"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{Binding MiniPrecipText}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap"
                    Visibility="{Binding MiniPrecipVisibility}" />
            </StackPanel>
        </Grid>

        <!-- ─── Compact Layout ─── -->
        <Grid
            x:Name="CompactLayout"
            Padding="10,8"
            RowSpacing="4"
            Visibility="{Binding CompactLayoutVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                    <FontIcon
                        FontSize="10"
                        Glyph="&#xE81D;"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock
                        FontSize="{Binding CaptionTextSize}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding LocationDisplay}"
                        TextWrapping="NoWrap"
                        TextTrimming="CharacterEllipsis"
                        VerticalAlignment="Center" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Click="RefreshButton_Click"
                    Style="{StaticResource WeatherIconButtonStyle}"
                    Width="24"
                    Height="24"
                    MinWidth="24"
                    MinHeight="24"
                    ToolTipService.ToolTip="{Binding RefreshTooltip}">
                    <FontIcon FontSize="11" Glyph="&#xE72C;" />
                </Button>
            </Grid>

            <Grid
                Grid.Row="1"
                ColumnSpacing="8"
                VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    FontSize="{Binding CurrentEmojiSize}"
                    Text="{Binding CurrentEmoji}"
                    VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Spacing="0" VerticalAlignment="Center">
                    <TextBlock
                        FontSize="{Binding TemperatureTextSize}"
                        FontWeight="SemiBold"
                        Text="{Binding CurrentTemperatureText}"
                        TextWrapping="NoWrap" />
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock
                            FontSize="{Binding CaptionTextSize}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding CurrentDescription}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />
                        <TextBlock
                            FontSize="{Binding CaptionTextSize}"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="{Binding ApparentTemperatureText}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Border
                Grid.Row="2"
                Padding="0,5,0,0"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
                <Grid ColumnSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        HorizontalAlignment="Center"
                        FontSize="{Binding CaptionTextSize}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding HumidityText}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap"
                        Visibility="{Binding HumidityVisibility}" />
                    <TextBlock
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        FontSize="{Binding CaptionTextSize}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding WindText}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap"
                        Visibility="{Binding WindVisibility}" />
                    <TextBlock
                        Grid.Column="2"
                        HorizontalAlignment="Center"
                        FontSize="{Binding CaptionTextSize}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding PrecipitationText}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap"
                        Visibility="{Binding PrecipitationVisibility}" />
                </Grid>
            </Border>
        </Grid>

        <!-- ─── Expanded Layout (merged Standard+Detailed, flexible internals) ─── -->
        <Grid
            x:Name="ExpandedLayout"
            Padding="16,12"
            RowSpacing="6"
            Visibility="{Binding ExpandedLayoutVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top row: Location + view switch + refresh -->
            <Grid Grid.Row="0" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="6"
                    VerticalAlignment="Center">
                    <FontIcon
                        FontSize="{Binding CaptionTextSize}"
                        Glyph="&#xE81D;"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        FontSize="{Binding BodyTextSize}"
                        FontWeight="SemiBold"
                        Text="{Binding LocationDisplay}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Click="ViewSwitch_Click"
                    Style="{StaticResource WeatherIconButtonStyle}"
                    Padding="8,2"
                    Width="Auto"
                    ToolTipService.ToolTip="{Binding ViewSwitchTooltip}"
                    Visibility="{Binding ViewSwitchVisibility}">
                    <TextBlock FontSize="{Binding CaptionTextSize}" Text="{Binding ViewSwitchText}" />
                </Button>
                <Button
                    Grid.Column="2"
                    Click="RefreshButton_Click"
                    Style="{StaticResource WeatherIconButtonStyle}"
                    ToolTipService.ToolTip="{Binding RefreshTooltip}">
                    <FontIcon FontSize="12" Glyph="&#xE72C;" />
                </Button>
            </Grid>

            <!-- Hero: icon + temperature, centered -->
            <StackPanel
                Grid.Row="1"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="14"
                VerticalAlignment="Center"
                Margin="0,4,0,0">
                <TextBlock
                    FontSize="{Binding CurrentEmojiSize}"
                    Text="{Binding CurrentEmoji}"
                    VerticalAlignment="Center" />
                <TextBlock
                    FontSize="{Binding TemperatureTextSize}"
                    FontWeight="Bold"
                    Text="{Binding CurrentTemperatureText}"
                    VerticalAlignment="Center" />
            </StackPanel>

            <!-- Description + feels like -->
            <StackPanel
                Grid.Row="2"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="12">
                <TextBlock
                    FontSize="{Binding TitleTextSize}"
                    Text="{Binding CurrentDescription}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap" />
                <TextBlock
                    FontSize="{Binding BodyTextSize}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding ApparentTemperatureText}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap" />
            </StackPanel>

            <!-- Metrics row with icons + bottom divider -->
            <Border
                Grid.Row="3"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="0,4,0,8">
                <StackPanel
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{Binding HumidityVisibility}">
                        <FontIcon FontSize="11" Glyph="&#xE798;" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock
                            FontSize="{Binding CaptionTextSize}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding HumidityText}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{Binding WindVisibility}">
                        <FontIcon FontSize="11" Glyph="&#xE8BD;" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock
                            FontSize="{Binding CaptionTextSize}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding WindText}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{Binding PrecipitationVisibility}">
                        <FontIcon FontSize="11" Glyph="&#xE755;" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock
                            FontSize="{Binding CaptionTextSize}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding PrecipitationText}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{Binding UvIndexVisibility}">
                        <FontIcon FontSize="11" Glyph="&#xE706;" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock
                            FontSize="{Binding CaptionTextSize}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding UvIndexText}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{Binding PressureVisibility}">
                        <FontIcon FontSize="11" Glyph="&#xE9D2;" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock
                            FontSize="{Binding CaptionTextSize}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding PressureText}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Sunrise / Sunset (shown when height allows) -->
            <Border
                Grid.Row="4"
                Padding="0,6,0,0"
                Visibility="{Binding ExpandedSunriseVisibility}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel
                        Grid.Column="0"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="6">
                        <FontIcon FontSize="12" Glyph="&#xE706;" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock
                            FontSize="{Binding CaptionTextSize}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding SunriseText}" />
                    </StackPanel>
                    <StackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="6">
                        <FontIcon FontSize="12" Glyph="&#xE708;" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock
                            FontSize="{Binding CaptionTextSize}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding SunsetText}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Today view: hourly horizontal scroll (borderless translucent cards) -->
            <ScrollViewer
                x:Name="ExpandedHourlyScroll"
                Grid.Row="5"
                HorizontalScrollMode="Disabled"
                VerticalScrollMode="Disabled"
                HorizontalScrollBarVisibility="Hidden"
                VerticalScrollBarVisibility="Disabled"
                Visibility="{Binding ForecastVisibility}"
                PointerWheelChanged="HourlyScroll_PointerWheelChanged"
                PointerPressed="ForecastScroll_PointerPressed"
                PointerMoved="ForecastScroll_PointerMoved"
                PointerReleased="ForecastScroll_PointerReleased"
                PointerCaptureLost="ForecastScroll_PointerCaptureLost">
                <ItemsControl
                    HorizontalAlignment="Left"
                    ItemsSource="{Binding HourlyForecast}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Width="{Binding DataContext.HourlyCardWidth, ElementName=ExpandedLayout}"
                                Height="{Binding DataContext.ExpandedHourlyCardHeight, ElementName=ExpandedLayout}"
                                CornerRadius="8"
                                Padding="0,6"
                                Background="{Binding IsCurrentHour, Converter={StaticResource CurrentHourBackgroundConverter}}">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="10"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Text="{Binding HourLabel}" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="16"
                                        Text="{Binding Emoji}" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="{Binding TemperatureText}"
                                        Visibility="{Binding IsCurrentHour, Converter={StaticResource NotCurrentHourVisibility}}" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                        Text="{Binding TemperatureText}"
                                        Visibility="{Binding IsCurrentHour, Converter={StaticResource IsCurrentHourVisibility}}" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="10"
                                        Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                        Text="{Binding PrecipitationText}"
                                        Visibility="{Binding DataContext.ExpandedHourlyPrecipVisibility, ElementName=ExpandedLayout}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Week forecast (scrollable, fills remaining space) -->
            <ScrollViewer
                x:Name="ExpandedWeekScroll"
                Grid.Row="5"
                HorizontalScrollMode="Disabled"
                VerticalScrollMode="Disabled"
                VerticalScrollBarVisibility="Hidden"
                HorizontalScrollBarVisibility="Disabled"
                Visibility="{Binding WeekForecastVisibility}"
                PointerWheelChanged="WeekScroll_PointerWheelChanged"
                PointerPressed="ForecastScroll_PointerPressed"
                PointerMoved="ForecastScroll_PointerMoved"
                PointerReleased="ForecastScroll_PointerReleased"
                PointerCaptureLost="ForecastScroll_PointerCaptureLost">
                <ItemsControl ItemsSource="{Binding DailyForecast}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid
                                Margin="0,2"
                                ColumnSpacing="10"
                                Padding="0,4"
                                ToolTipService.ToolTip="{Binding Description}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    FontSize="{Binding DataContext.WeekDayLabelTextSize, ElementName=ExpandedLayout}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding DayLabel}"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    Grid.Column="1"
                                    FontSize="{Binding DataContext.WeekEmojiSize, ElementName=ExpandedLayout}"
                                    Text="{Binding Emoji}"
                                    VerticalAlignment="Center" />
                                <!-- Temperature range bar -->
                                <Border
                                    Grid.Column="2"
                                    Height="4"
                                    CornerRadius="2"
                                    VerticalAlignment="Center"
                                    Margin="{Binding Converter={StaticResource TempBarMarginConverter}}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Offset="0" Color="{ThemeResource SystemAccentColorLight2}" />
                                            <GradientStop Offset="1" Color="{ThemeResource SystemAccentColor}" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <TextBlock
                                    Grid.Column="3"
                                    FontSize="{Binding DataContext.WeekTempMaxSize, ElementName=ExpandedLayout}"
                                    FontWeight="SemiBold"
                                    Text="{Binding TempMaxText}"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    Grid.Column="4"
                                    FontSize="{Binding DataContext.WeekTempMinSize, ElementName=ExpandedLayout}"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="{Binding TempMinText}"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ─── Refresh Status Toast ─── -->
        <Border
            x:Name="RefreshStatusToast"
            Padding="10,6"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            CornerRadius="6"
            Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            Visibility="{Binding RefreshStatusVisibility}">
            <TextBlock
                FontSize="11"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{Binding RefreshStatusText}" />
        </Border>

        <!-- ─── Loading Overlay (first-time fetch + user-triggered refresh) ─── -->
        <Grid
            x:Name="LoadingOverlay"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            CornerRadius="8"
            Visibility="{Binding LoadingVisibility}">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
                <ProgressRing
                    Width="24"
                    Height="24"
                    IsActive="True" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="11"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding LoadingText}" />
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
