<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DeskBox.Controls.WidgetShell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        x:Name="ShellRoot"
        Background="Transparent"
        PointerEntered="ShellRoot_PointerEntered"
        PointerExited="ShellRoot_PointerExited">
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            x:Name="BackgroundPlate"
            Grid.RowSpan="2"
            BorderThickness="0"
            CornerRadius="0" />

        <Grid
            x:Name="TitleBarGrid"
            Grid.Row="0"
            Padding="14,7,12,5"
            Background="Transparent"
            PointerMoved="TitleBarGrid_PointerMoved"
            PointerPressed="TitleBarGrid_PointerPressed"
            PointerReleased="TitleBarGrid_PointerReleased"
            RightTapped="TitleBarGrid_RightTapped">
            <ContentPresenter
                x:Name="CustomTitleBarContentPresenter"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Content="{x:Bind TitleBarContent, Mode=OneWay}" />

            <Grid x:Name="DefaultTitleBarContentHost">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="8">
                    <FontIcon
                        x:Name="TitleIcon"
                        FontSize="{Binding TitleIconSize}"
                        Glyph="{x:Bind TitleGlyph, Mode=OneWay}" />
                    <TextBlock
                        x:Name="TitleText"
                        FontSize="{Binding TitleTextSize}"
                        Text="{Binding DisplayName}"
                        TextTrimming="CharacterEllipsis"
                        VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel
                    x:Name="RightActionButtons"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="4"
                    Opacity="0"
                    VerticalAlignment="Center">
                    <Button
                        x:Name="MoreButton"
                        Width="22"
                        Height="22"
                        Click="MoreButton_Click"
                        Padding="0">
                        <FontIcon x:Name="MoreButtonIcon" FontSize="11" Glyph="&#xE712;" />
                    </Button>
                    <Button
                        x:Name="CloseButton"
                        Width="22"
                        Height="22"
                        Click="CloseButton_Click"
                        Padding="0">
                        <FontIcon x:Name="CloseButtonIcon" FontSize="11" Glyph="&#xE74D;" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <Border
            x:Name="HeaderDivider"
            Grid.Row="0"
            Height="1"
            Margin="12,0"
            VerticalAlignment="Bottom" />

        <ContentPresenter
            Grid.Row="1"
            Content="{x:Bind ShellContent, Mode=OneWay}" />
    </Grid>
</UserControl>
