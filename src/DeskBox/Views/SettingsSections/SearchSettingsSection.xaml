<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DeskBox.Views.SettingsSections.SearchSettingsSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:DeskBox.Services"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Styles/SettingsOverviewResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Style="{StaticResource SectionPanelStyle}">
        <TextBlock Style="{StaticResource SectionTitleTextStyle}" svc:Localized.Key="Settings.Search.Title" />
        <StackPanel Margin="0,8,0,0" Spacing="4">

            <!-- Hotkey enable -->
            <toolkit:SettingsCard
                HorizontalContentAlignment="Right"
                svc:Localized.DescriptionKey="Settings.Search.Hotkey.Description"
                svc:Localized.HeaderKey="Settings.Search.Hotkey.Title">
                <toolkit:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE765;" />
                </toolkit:SettingsCard.HeaderIcon>
                <ToggleSwitch
                    x:Name="SearchHotkeyToggle"
                    OnContent=""
                    OffContent=""
                    MinWidth="0"
                    Toggled="SearchHotkeyToggle_Toggled" />
            </toolkit:SettingsCard>

            <!-- Hotkey capture -->
            <toolkit:SettingsCard
                ContentAlignment="Vertical"
                HorizontalContentAlignment="Stretch"
                svc:Localized.HeaderKey="Settings.Search.Hotkey.CustomTitle">
                <toolkit:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE765;" />
                </toolkit:SettingsCard.HeaderIcon>
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        x:Name="SearchHotkeyStatusText"
                        Grid.Row="0"
                        VerticalAlignment="Center"
                        Style="{StaticResource SettingDescriptionTextStyle}" />
                    <Grid Grid.Row="1" MinWidth="252" HorizontalAlignment="Right" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button
                            x:Name="SearchHotkeyCaptureButton"
                            Grid.Column="0"
                            MinWidth="132"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource ActionButtonStyle}"
                            svc:Localized.ToolTipKey="Settings.Search.Hotkey.ChangeTooltip"
                            Click="SearchHotkeyCaptureButton_Click"
                            KeyDown="SearchHotkeyCaptureButton_KeyDown"
                            LostFocus="SearchHotkeyCaptureButton_LostFocus" />
                        <Button
                            x:Name="ResetSearchHotkeyButton"
                            Grid.Column="1"
                            Style="{StaticResource ActionButtonStyle}"
                            svc:Localized.ToolTipKey="Settings.Search.Hotkey.ResetTooltip"
                            Click="ResetSearchHotkeyButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Refresh" />
                                <TextBlock svc:Localized.Key="Common.Restore" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </toolkit:SettingsCard>

            <StackPanel Style="{StaticResource SettingsSubsectionHeaderStyle}">
                <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" svc:Localized.Key="Settings.Search.Scope.Title" />
                <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.Search.Scope.Description" />
            </StackPanel>

            <!-- Scope: DeskBox content -->
            <toolkit:SettingsCard
                HorizontalContentAlignment="Right"
                svc:Localized.DescriptionKey="Settings.Search.Scope.DeskBox.Description"
                svc:Localized.HeaderKey="Settings.Search.Scope.DeskBox">
                <ToggleSwitch
                    x:Name="SearchDeskBoxContentToggle"
                    OnContent=""
                    OffContent=""
                    MinWidth="0"
                    Toggled="SearchScopeToggle_Toggled" />
            </toolkit:SettingsCard>

            <!-- Scope: System index -->
            <toolkit:SettingsCard
                HorizontalContentAlignment="Right"
                svc:Localized.DescriptionKey="Settings.Search.Scope.SystemIndex.Description"
                svc:Localized.HeaderKey="Settings.Search.Scope.SystemIndex">
                <ToggleSwitch
                    x:Name="SearchSystemIndexToggle"
                    OnContent=""
                    OffContent=""
                    MinWidth="0"
                    Toggled="SearchScopeToggle_Toggled" />
            </toolkit:SettingsCard>

            <!-- Scope: Custom indexer -->
            <toolkit:SettingsCard
                HorizontalContentAlignment="Right"
                svc:Localized.DescriptionKey="Settings.Search.Scope.CustomIndexer.Description"
                svc:Localized.HeaderKey="Settings.Search.Scope.CustomIndexer">
                <ToggleSwitch
                    x:Name="SearchCustomIndexerToggle"
                    OnContent=""
                    OffContent=""
                    MinWidth="0"
                    Toggled="SearchScopeToggle_Toggled" />
            </toolkit:SettingsCard>

            <!-- Index status dashboard (visible when custom indexer is enabled) -->
            <toolkit:SettingsCard
                x:Name="IndexDashboardCard"
                ContentAlignment="Vertical"
                HorizontalContentAlignment="Stretch"
                svc:Localized.HeaderKey="Settings.Search.Index.Dashboard.Title">
                <toolkit:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE945;" />
                </toolkit:SettingsCard.HeaderIcon>
                <StackPanel Spacing="10" Margin="0,4,0,4">
                    <!-- Status row -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SearchIndexStatusText" Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SettingDescriptionTextStyle}" />
                        <TextBlock x:Name="SearchIndexCountText" Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SettingDescriptionTextStyle}"
                                   Opacity="0.7" />
                    </Grid>

                    <!-- Progress bar (indeterminate, visible while scanning) -->
                    <ProgressBar x:Name="IndexProgressBar"
                                 IsIndeterminate="True"
                                 Visibility="Collapsed" />

                    <!-- Storage + last scan info -->
                    <TextBlock x:Name="SearchIndexStorageText"
                               Style="{StaticResource SettingDescriptionTextStyle}"
                               Opacity="0.7" />

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="IndexPauseResumeButton"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="IndexPauseResumeButton_Click"
                                IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon x:Name="IndexPauseResumeIcon" Glyph="&#xE769;" FontSize="12" />
                                <TextBlock x:Name="IndexPauseResumeLabel" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="IndexRebuildButton"
                                Style="{StaticResource ActionButtonStyle}"
                                svc:Localized.ToolTipKey="Settings.Search.Index.Rebuild.Tooltip"
                                Click="IndexRebuildButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Refresh" />
                                <TextBlock svc:Localized.Key="Settings.Search.Index.Rebuild" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </toolkit:SettingsCard>

            <!-- Recommendations -->
            <toolkit:SettingsCard
                HorizontalContentAlignment="Right"
                svc:Localized.DescriptionKey="Settings.Search.Recommendations.Description"
                svc:Localized.HeaderKey="Settings.Search.Recommendations.Title">
                <toolkit:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8F1;" />
                </toolkit:SettingsCard.HeaderIcon>
                <ToggleSwitch
                    x:Name="SearchRecommendationsToggle"
                    OnContent=""
                    OffContent=""
                    MinWidth="0"
                    Toggled="SearchRecommendationsToggle_Toggled" />
            </toolkit:SettingsCard>

            <toolkit:SettingsCard
                HorizontalContentAlignment="Right"
                svc:Localized.DescriptionKey="Settings.Search.DefaultTab.Description"
                svc:Localized.HeaderKey="Settings.Search.DefaultTab.Title">
                <toolkit:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE7C5;" />
                </toolkit:SettingsCard.HeaderIcon>
                <ComboBox x:Name="SearchDefaultTabComboBox"
                          MinWidth="150"
                          SelectionChanged="SearchDefaultTabComboBox_SelectionChanged">
                    <ComboBoxItem Tag="all">
                        <TextBlock svc:Localized.Key="Search.Tab.All" />
                    </ComboBoxItem>
                    <ComboBoxItem Tag="app">
                        <TextBlock svc:Localized.Key="Search.Tab.App" />
                    </ComboBoxItem>
                    <ComboBoxItem Tag="file">
                        <TextBlock svc:Localized.Key="Search.Tab.File" />
                    </ComboBoxItem>
                    <ComboBoxItem Tag="deskbox">
                        <TextBlock svc:Localized.Key="Search.Tab.DeskBox" />
                    </ComboBoxItem>
                </ComboBox>
            </toolkit:SettingsCard>

            <!-- Max results -->
            <toolkit:SettingsCard
                HorizontalContentAlignment="Right"
                svc:Localized.DescriptionKey="Settings.Search.MaxResults.Description"
                svc:Localized.HeaderKey="Settings.Search.MaxResults.Title">
                <toolkit:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8FD;" />
                </toolkit:SettingsCard.HeaderIcon>
                <ComboBox x:Name="SearchMaxResultsComboBox"
                          MinWidth="100"
                          SelectionChanged="SearchMaxResultsComboBox_SelectionChanged">
                    <ComboBoxItem Tag="50" Content="50" />
                    <ComboBoxItem Tag="100" Content="100" />
                    <ComboBoxItem Tag="200" Content="200" />
                </ComboBox>
            </toolkit:SettingsCard>

            <!-- Icon animation style -->
            <toolkit:SettingsCard
                HorizontalContentAlignment="Right"
                svc:Localized.DescriptionKey="Settings.Search.IconAnimation.Description"
                svc:Localized.HeaderKey="Settings.Search.IconAnimation.Title">
                <toolkit:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE945;" />
                </toolkit:SettingsCard.HeaderIcon>
                <ComboBox x:Name="SearchIconAnimationComboBox"
                          MinWidth="130"
                          SelectionChanged="SearchIconAnimationComboBox_SelectionChanged">
                    <ComboBoxItem Tag="0">
                        <TextBlock svc:Localized.Key="Settings.Search.IconAnimation.Style0" />
                    </ComboBoxItem>
                    <ComboBoxItem Tag="1">
                        <TextBlock svc:Localized.Key="Settings.Search.IconAnimation.Style1" />
                    </ComboBoxItem>
                    <ComboBoxItem Tag="2">
                        <TextBlock svc:Localized.Key="Settings.Search.IconAnimation.Style2" />
                    </ComboBoxItem>
                    <ComboBoxItem Tag="3">
                        <TextBlock svc:Localized.Key="Settings.Search.IconAnimation.Style3" />
                    </ComboBoxItem>
                </ComboBox>
            </toolkit:SettingsCard>

            <toolkit:SettingsCard
                HorizontalContentAlignment="Right"
                svc:Localized.DescriptionKey="Settings.Search.Privacy.Description"
                svc:Localized.HeaderKey="Settings.Search.Privacy.Title">
                <toolkit:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE72E;" />
                </toolkit:SettingsCard.HeaderIcon>
                <Button Click="ClearSearchActivityButton_Click"
                        Style="{StaticResource ActionButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74D;" FontSize="12" />
                        <TextBlock svc:Localized.Key="Settings.Search.Privacy.Clear" />
                    </StackPanel>
                </Button>
            </toolkit:SettingsCard>

        </StackPanel>
    </StackPanel>
</UserControl>
