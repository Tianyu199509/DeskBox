                    <Border Style="{StaticResource SettingsGroupStyle}">
                        <StackPanel>
                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" Text="DeskBox" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.About.Description" />
                                </StackPanel>
                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource SettingValueTextStyle}"
                                    Text="{Binding AboutVersionText}" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <StackPanel Padding="16,14" Spacing="12">
                                <StackPanel Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.Download.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.Download.Description" />
                                </StackPanel>
                                <TextBox
                                    IsReadOnly="True"
                                    Text="https://pan.quark.cn/s/f7a6769cdaf3"
                                    TextWrapping="NoWrap" />
                                <StackPanel
                                    x:Name="DownloadLinkActionsPanel"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <Button
                                        x:Name="CopyDownloadLinkButton"
                                        Click="CopyDownloadLinkButton_Click"
                                        Style="{StaticResource ActionButtonStyle}"
                                        svc:Localized.ToolTipKey="Settings.Download.CopyTooltip">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Copy" />
                                            <TextBlock svc:Localized.Key="Common.Copy" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        x:Name="OpenDownloadLinkButton"
                                        Click="OpenDownloadLinkButton_Click"
                                        Style="{StaticResource ActionButtonStyle}"
                                        svc:Localized.ToolTipKey="Settings.Download.OpenTooltip">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="OpenFile" />
                                            <TextBlock svc:Localized.Key="Common.Open" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.About.ReasonTitle" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.About.Description" />
                                </StackPanel>
                                <Button
                                    Grid.Column="1"
                                    Click="ShowProductReasonButton_Click"
                                    Style="{StaticResource ActionButtonStyle}"
                                    svc:Localized.ToolTipKey="Settings.About.ReasonTitle">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="14" Glyph="&#xE946;" />
                                        <TextBlock svc:Localized.Key="Common.View" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.About.Repository" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" Text="{Binding OpenSourceRepositoryDisplayText}" />
                                </StackPanel>
                                <Button
                                    Grid.Column="1"
                                    Click="OpenRepositoryButton_Click"
                                    Style="{StaticResource ActionButtonStyle}"
                                    ToolTipService.ToolTip="{Binding OpenSourceRepositoryUrl}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="OpenFile" />
                                        <TextBlock svc:Localized.Key="Common.Open" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.About.WechatTitle" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.About.WechatDescription" />
                                </StackPanel>
                                <Image
                                    Grid.Column="1"
                                    Source="ms-appx:///Assets/wechat-qrcode.jpg"
                                    Width="100"
                                    Height="100"
                                    Stretch="Uniform"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
