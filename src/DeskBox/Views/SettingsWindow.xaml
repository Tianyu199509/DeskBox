<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DeskBox.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:media="using:Microsoft.UI.Xaml.Media.Imaging"
    xmlns:svc="using:DeskBox.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="DeskBox Settings">

    <Grid
        x:Name="SettingsRoot"
        MinWidth="800"
        MinHeight="560"
        IsTabStop="True"
        Background="Transparent">
        <Grid.Resources>
            <x:Double x:Key="NavigationViewCompactPaneLength">58</x:Double>
            <x:Double x:Key="NavigationViewItemOnLeftMinHeight">42</x:Double>
            <x:Double x:Key="NavigationViewItemOnLeftIconBoxHeight">22</x:Double>
            <Thickness x:Key="NavigationViewItemOnLeftIconBoxMargin">0</Thickness>
            <Thickness x:Key="NavigationViewItemButtonMargin">4,1,4,1</Thickness>
			
            <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="30" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
			
            <Style x:Key="PageDescriptionTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="SectionPanelStyle" TargetType="StackPanel">
                <Setter Property="Spacing" Value="4" />
            </Style>
			
            <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="Margin" Value="0,0,0,4" />
            </Style>
			
            <Style x:Key="SettingsGroupStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
            </Style>
			
            <Style x:Key="SettingsNavImageIconStyle" TargetType="ImageIcon">
                <Setter Property="Width" Value="28" />
                <Setter Property="Height" Value="28" />
            </Style>
			
            <Style x:Key="SettingRowStyle" TargetType="Grid">
                <Setter Property="Tag" Value="SettingRow" />
                <Setter Property="MinHeight" Value="64" />
                <Setter Property="Padding" Value="16,10" />
                <Setter Property="ColumnSpacing" Value="18" />
                <Setter Property="RowSpacing" Value="8" />
            </Style>
			
            <Style x:Key="SettingTextPanelStyle" TargetType="StackPanel">
                <Setter Property="Spacing" Value="3" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
			
            <Style x:Key="SettingTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
			
            <Style x:Key="SettingDescriptionTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="SettingsExpanderStyle" TargetType="Expander">
                <Setter Property="IsExpanded" Value="True" />
                <Setter Property="MinHeight" Value="70" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="0" />
            </Style>
			
            <Style x:Key="ExpanderHeaderIconStyle" TargetType="FontIcon">
                <Setter Property="Width" Value="28" />
                <Setter Property="FontSize" Value="17" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="FontFamily" Value="{ThemeResource SymbolThemeFontFamily}" />
            </Style>
			
            <Style x:Key="ExpanderHeaderTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
			
            <Style x:Key="ExpanderHeaderDescriptionTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="SettingValueTextStyle" TargetType="TextBlock" BasedOn="{StaticResource SettingDescriptionTextStyle}">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="SettingDividerStyle" TargetType="Border">
                <Setter Property="Height" Value="1" />
                <Setter Property="Margin" Value="16,0,0,0" />
                <Setter Property="Background" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
                <Setter Property="Opacity" Value="0.72" />
            </Style>

            <Style x:Key="InlineMetricSliderStyle" TargetType="Slider" BasedOn="{StaticResource DefaultSliderStyle}">
                <Setter Property="MinWidth" Value="180" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="IsThumbToolTipEnabled" Value="False" />
            </Style>

            <Style x:Key="CompactNumberBoxStyle" TargetType="NumberBox">
                <Setter Property="Width" Value="128" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Height" Value="32" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="ActionButtonStyle" TargetType="Button">
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="Height" Value="34" />
                <Setter Property="MinWidth" Value="104" />
                <Setter Property="Padding" Value="12,0" />
                <Setter Property="CornerRadius" Value="6" />
            </Style>

            <Style x:Key="IconActionButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="34" />
                <Setter Property="Height" Value="34" />
                <Setter Property="MinWidth" Value="34" />
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style x:Key="CompactTextActionButtonStyle" TargetType="Button">
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="Height" Value="32" />
                <Setter Property="MinWidth" Value="54" />
                <Setter Property="Padding" Value="12,0" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style x:Key="DrillDownRowStyle" TargetType="Button">
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="MinHeight" Value="60" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
            </Style>
			
            <Style x:Key="AccentSwatchButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="26" />
                <Setter Property="Height" Value="26" />
                <Setter Property="MinWidth" Value="26" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="13" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="Background" Value="Transparent" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Padding="18,0,128,0"
            Background="Transparent">
            <StackPanel
                x:Name="TitleTextHost"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <Image
                    Width="18"
                    Height="18"
                    VerticalAlignment="Center"
                    Source="ms-appx:///Assets/deskbox.svg" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="DeskBox" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="13"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    svc:Localized.Key="Settings.Title" />
            </StackPanel>
        </Grid>

        <Border
            Grid.Row="0"
            Height="1"
            VerticalAlignment="Bottom"
            Background="{ThemeResource DividerStrokeColorDefaultBrush}"
            Opacity="0.18" />

        <NavigationView
            x:Name="SettingsNavigationView"
            Grid.Row="1"
            CompactPaneLength="58"
            IsBackButtonVisible="Visible"
            IsBackEnabled="True"
            IsPaneOpen="True"
            IsSettingsVisible="False"
            OpenPaneLength="224"
            PaneDisplayMode="Left"
            BackRequested="SettingsNavigationView_BackRequested"
            SelectionChanged="SettingsNavigationView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="GeneralNavItem"
                    Tag="General"
                    svc:Localized.Key="Settings.Nav.General">
                    <NavigationViewItem.Icon>
                        <ImageIcon Style="{StaticResource SettingsNavImageIconStyle}">
                            <ImageIcon.Source>
                                <media:SvgImageSource UriSource="ms-appx:///Assets/SettingsNavIcons/general.svg" />
                            </ImageIcon.Source>
                        </ImageIcon>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Tag="Appearance"
                    svc:Localized.Key="Settings.Nav.Appearance">
                    <NavigationViewItem.Icon>
                        <ImageIcon Style="{StaticResource SettingsNavImageIconStyle}">
                            <ImageIcon.Source>
                                <media:SvgImageSource UriSource="ms-appx:///Assets/SettingsNavIcons/appearance.svg" />
                            </ImageIcon.Source>
                        </ImageIcon>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="FileWidgetNavItem"
                    Tag="AppearanceDetail"
                    svc:Localized.Key="Settings.Nav.FileWidget">
                    <NavigationViewItem.Icon>
                        <ImageIcon Style="{StaticResource SettingsNavImageIconStyle}">
                            <ImageIcon.Source>
                                <media:SvgImageSource UriSource="ms-appx:///Assets/SettingsNavIcons/file-widget.svg" />
                            </ImageIcon.Source>
                        </ImageIcon>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="FeatureWidgetsNavItem"
                    Tag="FeatureWidgets"
                    svc:Localized.Key="Settings.Nav.FeatureWidgets">
                    <NavigationViewItem.Icon>
                        <ImageIcon Style="{StaticResource SettingsNavImageIconStyle}">
                            <ImageIcon.Source>
                                <media:SvgImageSource UriSource="ms-appx:///Assets/SettingsNavIcons/feature-widgets.svg" />
                            </ImageIcon.Source>
                        </ImageIcon>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Tag="Interaction"
                    svc:Localized.Key="Settings.Nav.Interaction">
                    <NavigationViewItem.Icon>
                        <ImageIcon Style="{StaticResource SettingsNavImageIconStyle}">
                            <ImageIcon.Source>
                                <media:SvgImageSource UriSource="ms-appx:///Assets/SettingsNavIcons/interaction.svg" />
                            </ImageIcon.Source>
                        </ImageIcon>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Tag="Maintenance"
                    svc:Localized.Key="Settings.Nav.Maintenance">
                    <NavigationViewItem.Icon>
                        <ImageIcon Style="{StaticResource SettingsNavImageIconStyle}">
                            <ImageIcon.Source>
                                <media:SvgImageSource UriSource="ms-appx:///Assets/SettingsNavIcons/maintenance.svg" />
                            </ImageIcon.Source>
                        </ImageIcon>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Tag="About"
                    svc:Localized.Key="Settings.Nav.About">
                    <NavigationViewItem.Icon>
                        <ImageIcon Style="{StaticResource SettingsNavImageIconStyle}">
                            <ImageIcon.Source>
                                <media:SvgImageSource UriSource="ms-appx:///Assets/SettingsNavIcons/about.svg" />
                            </ImageIcon.Source>
                        </ImageIcon>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
			</NavigationView.MenuItems>

            <Grid x:Name="SettingsContentRoot">
                <ScrollViewer
                    x:Name="PageScroller"
                    Padding="20,16,20,38"
                    HorizontalContentAlignment="Stretch"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel
                        x:Name="ContentHost"
                        Width="760"
                        MaxWidth="760"
                        HorizontalAlignment="Center"
                        Spacing="24">
                <StackPanel
                    x:Name="AppearanceSection"
                    Visibility="Collapsed"
                    Style="{StaticResource SectionPanelStyle}">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" svc:Localized.Key="Settings.Section.Appearance" />
                    <Expander Style="{StaticResource SettingsExpanderStyle}">
                        <Expander.Header>
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE790;" Style="{StaticResource ExpanderHeaderIconStyle}" />
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Style="{StaticResource ExpanderHeaderTitleTextStyle}" svc:Localized.Key="Settings.Group.AppVisual.Title" />
                                    <TextBlock Style="{StaticResource ExpanderHeaderDescriptionTextStyle}" svc:Localized.Key="Settings.Group.AppVisual.Description" />
                                </StackPanel>
							</Grid>
                        </Expander.Header>
                        <Border Style="{StaticResource SettingsGroupStyle}">
                        <StackPanel>
                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.Theme.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.Theme.Description" />
                                </StackPanel>
                                <ComboBox
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    MinWidth="176"
                                    ItemsSource="{Binding AvailableThemeDisplayNames}"
                                    SelectedIndex="{Binding SelectedThemeIndex, Mode=OneWay}"
                                    SelectionChanged="SettingsComboBox_SelectionChanged"
                                    Tag="Theme" />
                            </Grid>
							
                            <Border Style="{StaticResource SettingDividerStyle}" />
							
                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>								
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.TrayIcon.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.TrayIcon.Description" />
                                </StackPanel>
                                <ComboBox
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    MinWidth="176"
                                    ItemsSource="{Binding AvailableTrayIconStyleDisplayNames}"
                                    SelectedIndex="{Binding SelectedTrayIconStyleIndex, Mode=OneWay}"
                                    SelectionChanged="SettingsComboBox_SelectionChanged"
                                    Tag="TrayIconStyle" />
                            </Grid>

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.SystemAccent.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.SystemAccent.Description" />
                                </StackPanel>
                                <ToggleSwitch
                                    Grid.Column="1"
                                    MinWidth="0"
                                    HorizontalAlignment="Right"
                                    IsOn="{Binding UseSystemAccentColor, Mode=TwoWay}" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.Accent.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" Text="{Binding AccentColorDescription}" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Orientation="Vertical"
                                    Spacing="8">
                                    <Button
                                        HorizontalAlignment="Right"
                                        Click="AccentColorButton_Click"
                                        IsEnabled="{Binding CanEditCustomAccent}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        svc:Localized.ToolTipKey="Settings.Accent.Tooltip">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border
                                                Width="16"
                                                Height="16"
                                                VerticalAlignment="Center"
                                                Background="{Binding AccentPreviewBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8" />
                                            <TextBlock VerticalAlignment="Center" Text="{Binding AccentColorHex}" />
                                        </StackPanel>
                                    </Button>
                                    <StackPanel
                                        HorizontalAlignment="Right"
                                        Orientation="Horizontal"
                                        Spacing="6">
                                        <Button
                                            Click="AccentPresetButton_Click"
                                            Style="{StaticResource AccentSwatchButtonStyle}"
                                            Tag="#0078D4"
                                            ToolTipService.ToolTip="#0078D4">
                                            <Border Width="16" Height="16" Background="#0078D4" CornerRadius="8" />
                                        </Button>
                                        <Button
                                            Click="AccentPresetButton_Click"
                                            Style="{StaticResource AccentSwatchButtonStyle}"
                                            Tag="#EF6950"
                                            ToolTipService.ToolTip="#EF6950">
                                            <Border Width="16" Height="16" Background="#EF6950" CornerRadius="8" />
                                        </Button>
                                        <Button
                                            Click="AccentPresetButton_Click"
                                            Style="{StaticResource AccentSwatchButtonStyle}"
                                            Tag="#2D7D46"
                                            ToolTipService.ToolTip="#2D7D46">
                                            <Border Width="16" Height="16" Background="#2D7D46" CornerRadius="8" />
                                        </Button>
                                        <Button
                                            Click="AccentPresetButton_Click"
                                            Style="{StaticResource AccentSwatchButtonStyle}"
                                            Tag="#8764B8"
                                            ToolTipService.ToolTip="#8764B8">
                                            <Border Width="16" Height="16" Background="#8764B8" CornerRadius="8" />
                                        </Button>
                                        <Button
                                            Click="AccentPresetButton_Click"
                                            Style="{StaticResource AccentSwatchButtonStyle}"
                                            Tag="#D83B01"
                                            ToolTipService.ToolTip="#D83B01">
                                            <Border Width="16" Height="16" Background="#D83B01" CornerRadius="8" />
                                        </Button>
                                        <Button
                                            Click="AccentPresetButton_Click"
                                            Style="{StaticResource AccentSwatchButtonStyle}"
                                            Tag="#038387"
                                            ToolTipService.ToolTip="#038387">
                                            <Border Width="16" Height="16" Background="#038387" CornerRadius="8" />
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
							
                            <Border Style="{StaticResource SettingDividerStyle}" />
							
                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.Corner.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.Corner.Description" />
                                </StackPanel>
                                <ComboBox
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    MinWidth="176"
                                    ItemsSource="{Binding AvailableWidgetCornerPreferenceDisplayNames}"
                                    SelectedIndex="{Binding SelectedWidgetCornerPreferenceIndex, Mode=OneWay}"
                                    SelectionChanged="SettingsComboBox_SelectionChanged"
                                    Tag="WidgetCorner" />
                            </Grid>
							
                            <Border Style="{StaticResource SettingDividerStyle}" />
							
                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.DisplayWidgetChrome.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.DisplayWidgetChrome.Description" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <Button
                                        Command="{Binding ResetDisplayWidgetChromeOverridesCommand}"
                                        Style="{StaticResource IconActionButtonStyle}"
                                        svc:Localized.ToolTipKey="Settings.DisplayWidgetChrome.ResetTooltip">
                                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                                    </Button>
                                    <ComboBox
                                        MinWidth="176"
                                        ItemsSource="{Binding AvailableWidgetChromeModeDisplayNames}"
                                        SelectedIndex="{Binding SelectedDisplayWidgetChromeModeIndex, Mode=OneWay}"
                                        SelectionChanged="SettingsComboBox_SelectionChanged"
                                        Tag="DisplayWidgetChromeMode" />
                                </StackPanel>
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.InteractiveWidgetChrome.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.InteractiveWidgetChrome.Description" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <Button
                                        Command="{Binding ResetInteractiveWidgetChromeOverridesCommand}"
                                        Style="{StaticResource IconActionButtonStyle}"
                                        svc:Localized.ToolTipKey="Settings.InteractiveWidgetChrome.ResetTooltip">
                                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                                    </Button>
                                    <ComboBox
                                        MinWidth="176"
                                        ItemsSource="{Binding AvailableWidgetChromeModeDisplayNames}"
                                        SelectedIndex="{Binding SelectedInteractiveWidgetChromeModeIndex, Mode=OneWay}"
                                        SelectionChanged="SettingsComboBox_SelectionChanged"
                                        Tag="InteractiveWidgetChromeMode" />
                                </StackPanel>
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.DefaultWidth.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.DefaultWidth.Description" />
                                </StackPanel>
                                <NumberBox
                                    Grid.Column="1"
                                    Style="{StaticResource CompactNumberBoxStyle}"
                                    Minimum="200"
                                    Maximum="1200"
                                    Value="{Binding DefaultWidth, Mode=TwoWay}" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid Style="{StaticResource SettingRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.DefaultHeight.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" svc:Localized.Key="Settings.DefaultHeight.Description" />
                                </StackPanel>
                                <NumberBox
                                    Grid.Column="1"
                                    Style="{StaticResource CompactNumberBoxStyle}"
                                    Minimum="200"
                                    Maximum="1200"
                                    Value="{Binding DefaultHeight, Mode=TwoWay}" />
                            </Grid>

                            <Border Style="{StaticResource SettingDividerStyle}" />

                            <Grid
                                Padding="16,14"
                                ColumnSpacing="16"
                                RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="176" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Style="{StaticResource SettingTextPanelStyle}">
                                    <TextBlock Style="{StaticResource SettingTitleTextStyle}" svc:Localized.Key="Settings.Opacity.Title" />
                                    <TextBlock Style="{StaticResource SettingDescriptionTextStyle}" Text="{Binding WidgetOpacityValueText}" />
                                </StackPanel>
                                <Slider
                                    Grid.Column="1"
                                    Maximum="1"
                                    Minimum="0"
                                    StepFrequency="0.02"
                                    Style="{StaticResource InlineMetricSliderStyle}"
