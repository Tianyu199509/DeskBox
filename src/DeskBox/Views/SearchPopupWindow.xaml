<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DeskBox.Views.SearchPopupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:DeskBox.Controls"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        Root stays transparent so the native backdrop (Mica/Acrylic per settings) shows
        through; Solid mode paints a frosted surface color in code-behind. Window corner
        rounding is applied at the OS level via DWM (see code-behind), which clips the
        backdrop itself rather than faking it with a CornerRadius.
    -->
    <Grid x:Name="RootGrid" IsTabStop="True" KeyDown="RootGrid_KeyDown"
          RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="PopupTranslateTransform"/>
        </Grid.RenderTransform>
        <Grid.Resources>
            <!-- Restrained opacity/translation motion keeps hotkey toggles calm and interruptible. -->
            <Storyboard x:Name="PopupShowStoryboard">
                <DoubleAnimation Storyboard.TargetName="RootGrid"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.92" To="1" Duration="0:0:0.16">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="PopupTranslateTransform"
                                 Storyboard.TargetProperty="Y"
                                 From="6" To="0" Duration="0:0:0.16">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
            <Storyboard x:Name="PopupHideStoryboard">
                <DoubleAnimation Storyboard.TargetName="RootGrid"
                                 Storyboard.TargetProperty="Opacity"
                                 From="1" To="0" Duration="0:0:0.11">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseIn"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="PopupTranslateTransform"
                                 Storyboard.TargetProperty="Y"
                                 From="0" To="-3" Duration="0:0:0.11">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseIn"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!--
                Horizontal quick-action button (New todo / New note / Open settings).
                One row, equal-width cells, Fluent control-fill ladder on hover/press.
            -->
            <Style x:Key="QuickButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource ControlFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="MinHeight" Value="34"/>
                <Setter Property="Padding" Value="8,0"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter x:Name="ContentPresenter"
                                              Background="{TemplateBinding Background}"
                                              BorderBrush="{TemplateBinding BorderBrush}"
                                              BorderThickness="{TemplateBinding BorderThickness}"
                                              CornerRadius="{TemplateBinding CornerRadius}"
                                              Padding="{TemplateBinding Padding}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              ContentTransitions="{TemplateBinding ContentTransitions}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                               Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0"
                                                                            Value="{ThemeResource ControlFillColorSecondaryBrush}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                               Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0"
                                                                            Value="{ThemeResource ControlFillColorTertiaryBrush}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </ContentPresenter>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Explicit rounded selection surface keeps every tab state inside the pill. -->
            <Style x:Key="TabPillItemStyle" TargetType="ListViewItem">
                <Setter Property="Margin" Value="0,0,5,5"/>
                <Setter Property="MinHeight" Value="32"/>
                <Setter Property="Padding" Value="9,4"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Grid>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="TabSurface" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="TabSurface" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Selected">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="TabSurface" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ControlFillColorSecondaryBrush}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                                <DoubleAnimation Storyboard.TargetName="TabSelectionIndicator" Storyboard.TargetProperty="Opacity" To="1" Duration="0"/>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="PointerOverSelected">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="TabSurface" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ControlFillColorTertiaryBrush}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                                <DoubleAnimation Storyboard.TargetName="TabSelectionIndicator" Storyboard.TargetProperty="Opacity" To="1" Duration="0"/>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="PressedSelected">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="TabSurface" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                                <DoubleAnimation Storyboard.TargetName="TabSelectionIndicator" Storyboard.TargetProperty="Opacity" To="1" Duration="0"/>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <Border x:Name="TabSurface"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                </Border>
                                <!-- Accent indicator bar below the tab pill, outside the Border so it is never clipped -->
                                <Border x:Name="TabSelectionIndicator" Height="2.5" Width="20"
                                        CornerRadius="1.25" Opacity="0"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                        Margin="0,0,0,1"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Tab pill content: glyph + name + count badge. -->
            <DataTemplate x:Key="TabPillTemplate">
                <StackPanel Orientation="Horizontal">
                    <FontIcon Glyph="{Binding Glyph}" FontSize="12"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding DisplayName}" FontSize="12.5"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="7" Padding="5,0,5,1" Margin="6,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding Count}" FontSize="10.5"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </DataTemplate>

            <!--
                Sortable column header: transparent at rest, subtle fill on hover.
                The direction glyph is toggled in code-behind.
            -->
            <Style x:Key="SortHeaderButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="CornerRadius" Value="5"/>
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter x:Name="ContentPresenter"
                                              Background="{TemplateBinding Background}"
                                              CornerRadius="{TemplateBinding CornerRadius}"
                                              Padding="{TemplateBinding Padding}"
                                              Content="{TemplateBinding Content}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                               Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0"
                                                                            Value="{ThemeResource SubtleFillColorSecondaryBrush}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                               Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0"
                                                                            Value="{ThemeResource SubtleFillColorTertiaryBrush}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </ContentPresenter>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Row 0: search box with icon, input, keycap badge and focus underline ── -->
        <Grid x:Name="SearchBoxRow" Grid.Row="0" Padding="12,12,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="SearchBoxBorder" Grid.Column="0" CornerRadius="8" Margin="0,0,8,0"
                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid Padding="14,8,12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0" Width="18" Height="18"
                           Source="/Assets/WidgetTitleIcons/search.svg"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>

                    <!--
                        MinHeight=0 is the alignment fix: the default TextBox template keeps a
                        32px minimum height and paints the text at the top of it, which made the
                        typed text sit visibly above the box's optical center. Letting the box
                        collapse to the text height lets VerticalAlignment=Center do its job.
                    -->
                    <TextBox x:Name="SearchTextBox" Grid.Column="1"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="15"
                             Padding="0"
                             MinHeight="0"
                             VerticalAlignment="Center"
                             TextChanged="SearchTextBox_TextChanged"
                             KeyDown="SearchTextBox_KeyDown">
                        <!--
                            The default WinUI 3 TextBox template re-paints its own chrome on
                            PointerOver/Focused: the visual states animate the background back to an
                            opaque fill and the border back to a 2px accent bottom edge, overriding the
                            local Background=Transparent / BorderThickness=0. Overriding these theme
                            resources to transparent keeps the native template fully functional (caret,
                            selection, placeholder) while leaving only the outer search-box chrome.
                        -->
                        <TextBox.Resources>
                            <SolidColorBrush x:Key="TextControlBackground" Color="Transparent"/>
                            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent"/>
                            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent"/>
                            <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent"/>
                            <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent"/>
                            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent"/>
                            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent"/>
                            <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent"/>
                            <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                            <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- Keycap-style hotkey badge -->
                    <Border x:Name="HotkeyHintBadge" Grid.Column="2" Padding="7,3,7,4" CornerRadius="5"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock x:Name="HotkeyHintText" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Button x:Name="ClosePopupButton" Grid.Column="1"
                    Width="32" Height="32" Padding="0"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="Transparent" BorderThickness="0"
                    Click="ClosePopupButton_Click">
                <FontIcon Glyph="&#xE8BB;" FontSize="12"/>
            </Button>

            <ProgressBar x:Name="SearchProgressBar" Height="2"
                         Grid.Column="0"
                         Margin="18,0,18,-5" VerticalAlignment="Bottom"
                         IsIndeterminate="True" Visibility="Collapsed"/>
        </Grid>

        <!-- ── Row 2: tab bar + filter combo on the right ── -->
        <Grid Grid.Row="2" Margin="12,0,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ListView x:Name="TabsList" Grid.Column="0"
                      SelectionMode="Single" IsTabStop="False"
                      ScrollViewer.HorizontalScrollMode="Disabled"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollMode="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                      Margin="0,8,0,4"
                      ItemContainerStyle="{StaticResource TabPillItemStyle}"
                      ItemTemplate="{StaticResource TabPillTemplate}"
                      SelectionChanged="TabsList_SelectionChanged">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <toolkit:WrapPanel Orientation="Horizontal"
                                           HorizontalSpacing="0" VerticalSpacing="0"/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
            </ListView>

            <Grid x:Name="ResultFilterBar" Grid.Column="1" Visibility="Collapsed"
                  Margin="8,8,0,4" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock x:Name="ResultFilterLabel" FontSize="11.5"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="ResultFilterComboBox" MinWidth="130" Height="30"
                              FontSize="12" SelectedIndex="0"
                              SelectionChanged="ResultFilterComboBox_SelectionChanged">
                        <ComboBoxItem x:Name="FilterAllItem" Tag="All"/>
                        <ComboBoxItem x:Name="FilterFilesItem" Tag="FilesAndFolders"/>
                        <ComboBoxItem x:Name="FilterAppsItem" Tag="Apps"/>
                        <ComboBoxItem x:Name="FilterImagesItem" Tag="Images"/>
                        <ComboBoxItem x:Name="FilterDocumentsItem" Tag="Documents"/>
                        <ComboBoxItem x:Name="FilterDeskBoxItem" Tag="DeskBox"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ── Row 3: results area (sort header + list + empty states) ── -->
        <Grid Grid.Row="3" MinHeight="80">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ResultFilterBar moved to tab bar row (Row 2) -->

            <!--
                Sortable column headers, aligned with the result rows below.
                Column structure MUST mirror SearchResultRowControl exactly so
                the header text and data text share the same left edge:
                  col 0  Width 5   = selection bar gutter
                  col 1  Width 34  = icon column
                  col 2  Width *   = name (Title)
                  col 3  Width 75  = type
                  col 4  Width 90  = size
                  col 5  Width 110 = date
            -->

            <!--
                Semi-transparent background bar behind the header. Aligned L/R
                (Margin 12) with the tab/menu bar and filter buttons above so the
                bar's left & right edges line up with them. Color matches the
                subtle semi-transparent fill used by the tabs / hotkey badge
                (SubtleFillColorSecondaryBrush) so it reads as the same surface.
            -->
            <Border x:Name="SortHeaderBackground" Grid.Row="1" Visibility="Collapsed"
                    Margin="12,2,12,2" CornerRadius="6"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"/>

            <Grid x:Name="SortHeaderRow" Grid.Row="1" Visibility="Collapsed"
                  Margin="16,2,16,2"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                  BorderThickness="0,0,0,1"
                  Padding="0,4,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="34"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="75"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="SortNameHeader" Grid.Column="2"
                        Padding="0,6,0,6" HorizontalContentAlignment="Left"
                        Style="{StaticResource SortHeaderButtonStyle}" Click="SortNameHeader_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="SortNameLabel" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <FontIcon x:Name="SortNameDirection" Glyph="&#xE74A;" FontSize="9"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  Margin="5,0,0,0" Visibility="Collapsed" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="SortTypeHeader" Grid.Column="3"
                        Margin="-12,0,0,0"
                        Padding="4,6,6,6" HorizontalContentAlignment="Left"
                        Style="{StaticResource SortHeaderButtonStyle}" Click="SortTypeHeader_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="SortTypeLabel" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <FontIcon x:Name="SortTypeDirection" Glyph="&#xE74B;" FontSize="9"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  Margin="5,0,0,0" Visibility="Collapsed" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="SortSizeHeader" Grid.Column="4"
                        Margin="-12,0,0,0"
                        Padding="6,6,6,6" HorizontalContentAlignment="Left"
                        Style="{StaticResource SortHeaderButtonStyle}" Click="SortSizeHeader_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="SortSizeLabel" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <FontIcon x:Name="SortSizeDirection" Glyph="&#xE74B;" FontSize="9"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  Margin="5,0,0,0" Visibility="Collapsed" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="SortDateHeader" Grid.Column="5"
                        Margin="-12,0,0,0"
                        Padding="0,6,0,6" HorizontalContentAlignment="Left"
                        Style="{StaticResource SortHeaderButtonStyle}" Click="SortDateHeader_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="SortDateLabel" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <FontIcon x:Name="SortDateDirection" Glyph="&#xE74B;" FontSize="9"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  Margin="5,0,0,0" Visibility="Collapsed" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <TextBlock x:Name="HomeSectionHeader" Grid.Row="1"
                       Margin="12,5,12,7" FontSize="12.5" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="Collapsed"/>

            <!-- Result rows (SearchResultRowControl owns hover/selection visuals) -->
            <ScrollViewer x:Name="ResultsPanel" Grid.Row="2" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto" Padding="12,2,12,12"
                          KeyDown="ResultsPanel_KeyDown"
                          PointerPressed="ResultsPanel_PointerPressed"
                          PointerMoved="ResultsPanel_PointerMoved"
                          PointerReleased="ResultsPanel_PointerReleased"
                          DoubleTapped="ResultsPanel_DoubleTapped"
                          RightTapped="ResultsPanel_RightTapped">
                <ItemsRepeater x:Name="ResultsRepeater">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <controls:SearchResultRowControl/>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

            <!-- Empty tab: the selected tab has no items (empty state browsing) -->
            <StackPanel x:Name="EmptyTabHintPanel" Grid.Row="2" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Padding="0,20">
                <FontIcon Glyph="&#xE8B7;" FontSize="26"
                          Foreground="{ThemeResource TextFillColorDisabledBrush}"
                          HorizontalAlignment="Center"/>
                <TextBlock x:Name="EmptyTabHintText" FontSize="12.5"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>

            <!-- No-results empty state (query returned nothing) -->
            <StackPanel x:Name="NoResultsPanel" Grid.Row="2" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Padding="0,24">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="12"/>
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>
                <FontIcon Glyph="&#xE721;" FontSize="30"
                          Foreground="{ThemeResource TextFillColorDisabledBrush}"
                          HorizontalAlignment="Center"/>
                <TextBlock x:Name="NoResultsTitle" FontSize="14" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock x:Name="NoResultsSubtitle" FontSize="12"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Loading indicator -->
            <StackPanel x:Name="LoadingPanel" Grid.Row="2" Visibility="Collapsed"
                        HorizontalAlignment="Stretch" VerticalAlignment="Top"
                        Padding="18,16,18,0" Spacing="10">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="8" IsStaggeringEnabled="True"/>
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>
                <StackPanel Orientation="Horizontal" Spacing="9">
                    <ProgressRing x:Name="LoadingRing" Width="18" Height="18" IsActive="True"
                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                    <TextBlock x:Name="LoadingStatusText" FontSize="12.5" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" TextWrapping="NoWrap"/>
                </StackPanel>
                <Border Height="46" CornerRadius="7" Background="{ThemeResource SubtleFillColorSecondaryBrush}"/>
                <Border Height="46" CornerRadius="7" Background="{ThemeResource SubtleFillColorSecondaryBrush}" Opacity="0.82"/>
                <Border Height="46" CornerRadius="7" Background="{ThemeResource SubtleFillColorSecondaryBrush}" Opacity="0.64"/>
                <Border Height="46" CornerRadius="7" Background="{ThemeResource SubtleFillColorSecondaryBrush}" Opacity="0.46"/>
            </StackPanel>

            <!-- Skeleton placeholder shown while app icons are loading -->
            <ScrollViewer x:Name="AppsSkeletonPanel" Grid.Row="2" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Disabled" Padding="12,2,12,12">
                <ItemsRepeater x:Name="AppsSkeletonRepeater">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemHeight="92"
                                           MinColumnSpacing="6" MinRowSpacing="6"
                                           ItemsJustification="Start"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="104" Height="92" Padding="8,7" CornerRadius="7">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Width="36" Height="36" CornerRadius="8"
                                        HorizontalAlignment="Center"
                                        Background="{ThemeResource ControlFillColorSecondaryBrush}"/>
                                <Border Grid.Row="1" Width="56" Height="10" CornerRadius="5"
                                        HorizontalAlignment="Center" Margin="0,8,0,0"
                                        Background="{ThemeResource ControlFillColorSecondaryBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

            <!-- Empty-query application launcher. It intentionally does not reuse file rows. -->
            <ScrollViewer x:Name="RecommendedAppsPanel" Grid.Row="2" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto" Padding="12,2,12,12"
                          RightTapped="RecommendedAppsPanel_RightTapped">
                <ItemsRepeater x:Name="RecommendedAppsRepeater">

                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemHeight="92"
                                           MinColumnSpacing="6" MinRowSpacing="6"
                                           ItemsJustification="Start"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="104" Height="92" Padding="8,7" Margin="0"
                                  Background="Transparent" CornerRadius="7"
                                  PointerPressed="RecommendedApp_PointerPressed"
                                  PointerEntered="RecommendedApp_PointerEntered"
                                  PointerExited="RecommendedApp_PointerExited"
                                  DoubleTapped="RecommendedApp_DoubleTapped">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Width="40" Height="40" HorizontalAlignment="Center">
                                    <Image Source="{Binding Icon}" Width="36" Height="36"
                                           Stretch="Uniform"
                                           ImageOpened="OnAppIcon_ImageOpened"
                                           ImageFailed="OnAppIcon_ImageFailed"/>
                                </Grid>
                                <TextBlock Grid.Row="1" Text="{Binding AppDisplayName}" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           TextAlignment="Center" TextTrimming="CharacterEllipsis"
                                           MaxLines="1" TextWrapping="NoWrap"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

            <!-- Recommendation panel for empty state (history + favorites) -->
            <StackPanel x:Name="RecommendationPanel" Grid.Row="2" Visibility="Collapsed"
                        Padding="12,8,12,12" HorizontalAlignment="Stretch">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition IsStaggeringEnabled="True"/>
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>
                
                <!-- Favorites section -->
                <Grid x:Name="FavoritesSection" Margin="0,0,0,12" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header with count and clear button -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock x:Name="FavoritesHeaderText" Grid.Column="0" FontSize="12.5" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button x:Name="ClearAllButton" Grid.Column="1" FontSize="11"
                                Padding="8,4" CornerRadius="6"
                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Tag="all"
                                Click="ClearHistoryButton_Click">
                            <Button.Flyout>
                                <MenuFlyout Placement="Bottom">
                                    <MenuFlyoutItem x:Name="ConfirmClearAllItem" Click="ConfirmClearHistory_Click"/>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                    
                    <!-- Favorites list -->
                    <ItemsRepeater x:Name="FavoritesRepeater" MaxHeight="140">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,7" Margin="0,0,0,4" CornerRadius="7" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                    <Grid x:Name="RecItemGrid" PointerPressed="OnRecommendationItem_PointerPressed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="13"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        <FontIcon Grid.Column="1" Glyph="\uE9D9" FontSize="11"
                                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                  Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </Grid>
                
                <!-- Divider -->
                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,0,0,12"/>
                
                <!-- Recent searches section -->
                <Grid x:Name="RecentSearchesSection">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header with count and clear button -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock x:Name="RecentSearchesHeaderText" Grid.Column="0" FontSize="12.5" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button x:Name="ClearRecentButton" Grid.Column="1" FontSize="11"
                                Padding="8,4" CornerRadius="6"
                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Tag="recent"
                                Click="ClearHistoryButton_Click">
                            <Button.Flyout>
                                <MenuFlyout Placement="Bottom">
                                    <MenuFlyoutItem x:Name="ConfirmClearRecentItem" Click="ConfirmClearHistory_Click"/>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                    
                    <!-- Recent searches list -->
                    <ItemsRepeater x:Name="RecentSearchesRepeater" MaxHeight="140">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,7" Margin="0,0,0,4" CornerRadius="7" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                    <Grid x:Name="RecItemGrid" PointerPressed="OnRecommendationItem_PointerPressed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="13"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        <FontIcon Grid.Column="1" Glyph="\uE81C" FontSize="11"
                                                  Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                                  Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- Persistent footer: contextual result actions on the left, settings on the right. -->
        <Grid x:Name="FooterBar" Grid.Row="4" Padding="12,7" ColumnSpacing="8"
              Background="{ThemeResource LayerFillColorAltBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <toolkit:WrapPanel x:Name="SelectionActionBar" Grid.Column="0"
                               Orientation="Horizontal" HorizontalSpacing="6"
                               VerticalSpacing="6" Visibility="Collapsed">
                <Button x:Name="OpenSelectedButton" Padding="10,5"
                        Click="OpenSelectedButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8E5;" FontSize="12"/>
                        <TextBlock x:Name="OpenSelectedLabel"/>
                    </StackPanel>
                </Button>
                <Button x:Name="OpenLocationButton" Padding="10,5"
                        Click="OpenLocationButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE838;" FontSize="12"/>
                        <TextBlock x:Name="OpenLocationLabel"/>
                    </StackPanel>
                </Button>
                <Button x:Name="AttachSelectedButton" Padding="10,5"
                        Click="AttachSelectedButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE723;" FontSize="12"/>
                        <TextBlock x:Name="AttachSelectedLabel"/>
                    </StackPanel>
                </Button>
                <Button x:Name="SaveSelectedButton" Padding="10,5"
                        Click="SaveSelectedButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE70B;" FontSize="12"/>
                        <TextBlock x:Name="SaveSelectedLabel"/>
                    </StackPanel>
                </Button>
            </toolkit:WrapPanel>

            <Grid x:Name="StatusBar" Grid.Column="0" Visibility="Collapsed"
                  VerticalAlignment="Center">
                <TextBlock x:Name="StatusTextBlock" FontSize="11"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            </Grid>

            <Button x:Name="OpenSettingsButton" Grid.Column="1"
                    Style="{StaticResource QuickButtonStyle}"
                    MinHeight="30" Padding="9,0"
                    HorizontalAlignment="Right"
                    Click="OpenSettingsButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Image Source="/Assets/WidgetTitleIcons/settings.svg" Width="16" Height="16"/>
                    <TextBlock x:Name="OpenSettingsLabel" FontSize="12.5"/>
                </StackPanel>
            </Button>
        </Grid>

        <!--
            Settings-driven border overlay: thickness/color follow the widget border
            style settings (see ApplyMaterialFromSettings). Hit testing stays off so it
            never intercepts row interaction.
        -->
        <Border x:Name="PopupBorderOverlay" Grid.RowSpan="5"
                IsHitTestVisible="False" CornerRadius="8"/>

        <!--
            Drag hot zone is intentionally limited to a thin strip at the very top of
            the window so it no longer overlaps the search input box. The search box
            (SearchTextBox) lives inside SearchBoxRow (Grid.Row=0) below this strip and
            must remain fully clickable for text input. Only the top edge is draggable.
        -->
        <Grid x:Name="TopDragHotZone" Grid.Row="0"
              HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="14"
              Background="Transparent"
              PointerEntered="TopDragHotZone_PointerEntered"
              PointerExited="TopDragHotZone_PointerExited"
              PointerPressed="TopDragHotZone_PointerPressed"
              PointerMoved="WindowInteraction_PointerMoved"
              PointerReleased="WindowInteraction_PointerReleased"
              PointerCaptureLost="WindowInteraction_PointerCaptureLost"
              DoubleTapped="TopDragHotZone_DoubleTapped">
            <Border x:Name="TopDragHandle" Width="44" Height="4" CornerRadius="2"
                    HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0"
                    Background="{ThemeResource TextFillColorSecondaryBrush}"
                    Opacity="0" IsHitTestVisible="False"/>
        </Grid>

        <Grid x:Name="ResizeGrid" Grid.RowSpan="5" Canvas.ZIndex="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="7"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="7"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Background="Transparent" Tag="TopLeft" PointerEntered="ResizeBorder_PointerEntered" PointerPressed="ResizeBorder_PointerPressed" PointerMoved="WindowInteraction_PointerMoved" PointerReleased="WindowInteraction_PointerReleased" PointerCaptureLost="WindowInteraction_PointerCaptureLost"/>
            <Border Grid.Row="0" Grid.Column="1" Background="Transparent" Tag="Top" PointerEntered="ResizeBorder_PointerEntered" PointerPressed="ResizeBorder_PointerPressed" PointerMoved="WindowInteraction_PointerMoved" PointerReleased="WindowInteraction_PointerReleased" PointerCaptureLost="WindowInteraction_PointerCaptureLost"/>
            <Border Grid.Row="0" Grid.Column="2" Background="Transparent" Tag="TopRight" PointerEntered="ResizeBorder_PointerEntered" PointerPressed="ResizeBorder_PointerPressed" PointerMoved="WindowInteraction_PointerMoved" PointerReleased="WindowInteraction_PointerReleased" PointerCaptureLost="WindowInteraction_PointerCaptureLost"/>
            <Border Grid.Row="1" Grid.Column="0" Background="Transparent" Tag="Left" PointerEntered="ResizeBorder_PointerEntered" PointerPressed="ResizeBorder_PointerPressed" PointerMoved="WindowInteraction_PointerMoved" PointerReleased="WindowInteraction_PointerReleased" PointerCaptureLost="WindowInteraction_PointerCaptureLost"/>
            <Border Grid.Row="1" Grid.Column="2" Background="Transparent" Tag="Right" PointerEntered="ResizeBorder_PointerEntered" PointerPressed="ResizeBorder_PointerPressed" PointerMoved="WindowInteraction_PointerMoved" PointerReleased="WindowInteraction_PointerReleased" PointerCaptureLost="WindowInteraction_PointerCaptureLost"/>
            <Border Grid.Row="2" Grid.Column="0" Background="Transparent" Tag="BottomLeft" PointerEntered="ResizeBorder_PointerEntered" PointerPressed="ResizeBorder_PointerPressed" PointerMoved="WindowInteraction_PointerMoved" PointerReleased="WindowInteraction_PointerReleased" PointerCaptureLost="WindowInteraction_PointerCaptureLost"/>
            <Border Grid.Row="2" Grid.Column="1" Background="Transparent" Tag="Bottom" PointerEntered="ResizeBorder_PointerEntered" PointerPressed="ResizeBorder_PointerPressed" PointerMoved="WindowInteraction_PointerMoved" PointerReleased="WindowInteraction_PointerReleased" PointerCaptureLost="WindowInteraction_PointerCaptureLost"/>
            <Border Grid.Row="2" Grid.Column="2" Background="Transparent" Tag="BottomRight" PointerEntered="ResizeBorder_PointerEntered" PointerPressed="ResizeBorder_PointerPressed" PointerMoved="WindowInteraction_PointerMoved" PointerReleased="WindowInteraction_PointerReleased" PointerCaptureLost="WindowInteraction_PointerCaptureLost"/>
        </Grid>
    </Grid>
</Window>
