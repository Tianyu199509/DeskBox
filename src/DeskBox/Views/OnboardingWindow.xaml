<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DeskBox.Views.OnboardingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:DeskBox.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="DeskBox Onboarding">

    <Grid
        x:Name="RootGrid"
        MinWidth="660"
        MinHeight="540"
        Padding="40"
        Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">

        <Grid.Resources>
            <!-- ── Shared text styles ── -->
            <Style x:Key="StepEyebrowText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
            </Style>
            <Style x:Key="StepTitleText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="28"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                <Setter Property="LineHeight" Value="34"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>
            <Style x:Key="StepBodyText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Setter Property="LineHeight" Value="21"/>
                <Setter Property="TextWrapping" Value="WrapWholeWords"/>
            </Style>

            <!-- ── Card style ── -->
            <Style x:Key="SettingCard" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="16,14"/>
            </Style>

            <!-- ── Feature card style ── -->
            <Style x:Key="FeatureCard" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="18,16"/>
            </Style>

            <!-- ── Value highlight card style ── -->
            <Style x:Key="ValueCard" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="20,18"/>
            </Style>

            <!-- ── Hint row style ── -->
            <Style x:Key="HintIcon" TargetType="FontIcon">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
            </Style>
            <Style x:Key="HintText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12.5"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═════════════ Title Bar ═════════════ -->
        <Grid x:Name="TitleBarHost" Height="36" Margin="-40,-40,-40,6" Background="Transparent"/>

        <!-- ═════════════ Content Area ═════════════ -->
        <ScrollViewer
            x:Name="ContentScrollViewer"
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto">

            <Grid x:Name="StepContainer" MinHeight="420">

                <!-- ─────────── Step 1: Core Value Overview (3 highlight cards) ─────────── -->
                <StackPanel
                    x:Name="Step1Panel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="24"
                    MaxWidth="620">

                    <!-- Brand logo -->
                    <Grid
                        x:Name="BrandLogoHost"
                        Width="36"
                        Height="36"
                        HorizontalAlignment="Center"
                        Opacity="1">
                        <Grid.Clip>
                            <RectangleGeometry Rect="0,0,36,36"/>
                        </Grid.Clip>
                        <Image
                            x:Name="BrandLogo"
                            Width="36"
                            Height="36"
                            Source="ms-appx:///Assets/deskbox.svg"/>
                        <Border
                            x:Name="BrandLogoShine"
                            Width="14"
                            Height="54"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False"
                            Opacity="0.36"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0" Color="#00FFFFFF"/>
                                    <GradientStop Offset="0.5" Color="#A6FFFFFF"/>
                                    <GradientStop Offset="1" Color="#00FFFFFF"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.RenderTransform>
                                <CompositeTransform
                                    x:Name="BrandLogoShineTransform"
                                    Rotation="-18"
                                    TranslateX="-44"/>
                            </Border.RenderTransform>
                        </Border>
                    </Grid>

                    <!-- Title area -->
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <TextBlock
                            x:Name="Step1Eyebrow"
                            Style="{StaticResource StepEyebrowText}"
                            HorizontalAlignment="Center"
                            svc:Localized.Key="Onboarding.Step1.Eyebrow"/>
                        <TextBlock
                            x:Name="Step1Title"
                            Style="{StaticResource StepTitleText}"
                            HorizontalAlignment="Center"
                            TextAlignment="Center"
                            svc:Localized.Key="Onboarding.Step1.Title"/>
                        <TextBlock
                            x:Name="Step1Body"
                            Style="{StaticResource StepBodyText}"
                            HorizontalAlignment="Center"
                            MaxWidth="460"
                            TextAlignment="Center"
                            svc:Localized.Key="Onboarding.Step1.Body"/>
                    </StackPanel>

                    <!-- 3 Value highlight cards -->
                    <StackPanel x:Name="Step1ValueCards" Spacing="10" HorizontalAlignment="Center" MaxWidth="520">
                        <Border x:Name="Step1Card1" Style="{StaticResource ValueCard}">
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" CornerRadius="9" Background="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0.12" VerticalAlignment="Center"/>
                                <FontIcon Glyph="&#xE8B7;" FontSize="17" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <TextBlock FontSize="13.5" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" svc:Localized.Key="Onboarding.Step1.Value1Title"/>
                                    <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" svc:Localized.Key="Onboarding.Step1.Value1Body"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border x:Name="Step1Card2" Style="{StaticResource ValueCard}">
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" CornerRadius="9" Background="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0.12" VerticalAlignment="Center"/>
                                <FontIcon Glyph="&#xE721;" FontSize="17" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <TextBlock FontSize="13.5" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" svc:Localized.Key="Onboarding.Step1.Value2Title"/>
                                    <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" svc:Localized.Key="Onboarding.Step1.Value2Body"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border x:Name="Step1Card3" Style="{StaticResource ValueCard}">
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" CornerRadius="9" Background="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0.12" VerticalAlignment="Center"/>
                                <FontIcon Glyph="&#xE71D;" FontSize="17" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                    <TextBlock FontSize="13.5" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" svc:Localized.Key="Onboarding.Step1.Value3Title"/>
                                    <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" svc:Localized.Key="Onboarding.Step1.Value3Body"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Single hint -->
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE73E;" Style="{StaticResource HintIcon}"/>
                        <TextBlock Style="{StaticResource HintText}" svc:Localized.Key="Onboarding.Step1.Hint1"/>
                    </StackPanel>
                </StackPanel>

                <!-- ─────────── Step 2: Feature Widgets (grid with toggles) ─────────── -->
                <StackPanel
                    x:Name="Step2Panel"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="20"
                    MaxWidth="640">

                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource StepEyebrowText}" HorizontalAlignment="Center" svc:Localized.Key="Onboarding.Step2.Eyebrow"/>
                        <TextBlock Style="{StaticResource StepTitleText}" HorizontalAlignment="Center" TextAlignment="Center" svc:Localized.Key="Onboarding.Step2.Title"/>
                        <TextBlock Style="{StaticResource StepBodyText}" HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="480" svc:Localized.Key="Onboarding.Step2.Body"/>
                    </StackPanel>

                    <Grid x:Name="Step2CardGrid" ColumnSpacing="14" RowSpacing="14" MaxWidth="560" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Todo -->
                        <Border x:Name="Step2TodoCard" Grid.Row="0" Grid.Column="0" Style="{StaticResource FeatureCard}">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <FontIcon Glyph="&#xE8FD;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                                    <ToggleSwitch x:Name="Step2TodoToggle" OnContent="" OffContent="" MinWidth="0" HorizontalAlignment="Right" Toggled="Step2Toggle_Toggled"/>
                                </Grid>
                                <TextBlock FontSize="13.5" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" svc:Localized.Key="Onboarding.Step2.TodoTitle"/>
                                <TextBlock FontSize="11.5" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" svc:Localized.Key="Onboarding.Step2.TodoDescription"/>
                            </StackPanel>
                        </Border>

                        <!-- Quick Capture -->
                        <Border x:Name="Step2QuickCaptureCard" Grid.Row="0" Grid.Column="1" Style="{StaticResource FeatureCard}">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <FontIcon Glyph="&#xE70B;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                                    <ToggleSwitch x:Name="Step2QuickCaptureToggle" OnContent="" OffContent="" MinWidth="0" HorizontalAlignment="Right" Toggled="Step2Toggle_Toggled"/>
                                </Grid>
                                <TextBlock FontSize="13.5" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" svc:Localized.Key="Onboarding.Step2.QuickCaptureTitle"/>
                                <TextBlock FontSize="11.5" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" svc:Localized.Key="Onboarding.Step2.QuickCaptureDescription"/>
                            </StackPanel>
                        </Border>

                        <!-- Music -->
                        <Border x:Name="Step2MusicCard" Grid.Row="1" Grid.Column="0" Style="{StaticResource FeatureCard}">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <FontIcon Glyph="&#xE8D6;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                                    <ToggleSwitch x:Name="Step2MusicToggle" OnContent="" OffContent="" MinWidth="0" HorizontalAlignment="Right" Toggled="Step2Toggle_Toggled"/>
                                </Grid>
                                <TextBlock FontSize="13.5" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" svc:Localized.Key="Onboarding.Step2.MusicTitle"/>
                                <TextBlock FontSize="11.5" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" svc:Localized.Key="Onboarding.Step2.MusicDescription"/>
                            </StackPanel>
                        </Border>

                        <!-- Weather -->
                        <Border x:Name="Step2WeatherCard" Grid.Row="1" Grid.Column="1" Style="{StaticResource FeatureCard}">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <FontIcon Glyph="&#xE928;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Left"/>
                                    <ToggleSwitch x:Name="Step2WeatherToggle" OnContent="" OffContent="" MinWidth="0" HorizontalAlignment="Right" Toggled="Step2Toggle_Toggled"/>
                                </Grid>
                                <TextBlock FontSize="13.5" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" svc:Localized.Key="Onboarding.Step2.WeatherTitle"/>
                                <TextBlock FontSize="11.5" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" svc:Localized.Key="Onboarding.Step2.WeatherDescription"/>
                            </StackPanel>
                        </Border>

                        <!-- Search (spans 2 columns) -->
                        <Border x:Name="Step2SearchCard" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource FeatureCard}">
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE721;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock FontSize="13.5" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" svc:Localized.Key="Onboarding.Step2.SearchTitle"/>
                                    </StackPanel>
                                    <TextBlock FontSize="11.5" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" svc:Localized.Key="Onboarding.Step2.SearchDescription"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="Step2SearchToggle" Grid.Column="1" OnContent="" OffContent="" MinWidth="0" VerticalAlignment="Center" Toggled="Step2Toggle_Toggled"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Hint -->
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE73E;" Style="{StaticResource HintIcon}"/>
                        <TextBlock Style="{StaticResource HintText}" svc:Localized.Key="Onboarding.Step2.Hint1"/>
                    </StackPanel>
                </StackPanel>

                <!-- ─────────── Step 3: Appearance (controls + live preview + capsule) ─────────── -->
                <Grid
                    x:Name="Step3Panel"
                    Visibility="Collapsed"
                    ColumnSpacing="32"
                    MaxWidth="760"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Left: title + controls -->
                    <StackPanel Grid.Column="0" Spacing="18" MaxWidth="420">
                        <StackPanel Spacing="6">
                            <TextBlock Style="{StaticResource StepEyebrowText}" svc:Localized.Key="Onboarding.Step3.Eyebrow"/>
                            <TextBlock Style="{StaticResource StepTitleText}" svc:Localized.Key="Onboarding.Step3.Title"/>
                            <TextBlock Style="{StaticResource StepBodyText}" svc:Localized.Key="Onboarding.Step3.Body"/>
                        </StackPanel>

                        <!-- Theme selector -->
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" svc:Localized.Key="Onboarding.Step3.ThemeSection"/>
                            <StackPanel x:Name="Step3ThemeSelector" Orientation="Horizontal" Spacing="6"/>
                        </StackPanel>

                        <!-- Accent color selector -->
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" svc:Localized.Key="Onboarding.Step3.AccentSection"/>
                            <StackPanel x:Name="Step3AccentSelector" Orientation="Horizontal" Spacing="6"/>
                        </StackPanel>

                        <!-- Material selector -->
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" svc:Localized.Key="Onboarding.Step3.MaterialSection"/>
                            <StackPanel x:Name="Step3MaterialSelector" Orientation="Horizontal" Spacing="6"/>
                        </StackPanel>

                        <!-- Capsule mode toggle -->
                        <Border Style="{StaticResource SettingCard}" Padding="14,12">
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="3">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE73E;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" svc:Localized.Key="Onboarding.Step3.CapsuleTitle"/>
                                    </StackPanel>
                                    <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" svc:Localized.Key="Onboarding.Step3.CapsuleDescription"/>
                                </StackPanel>
                                <ToggleSwitch
                                    x:Name="Step3CapsuleToggle"
                                    Grid.Column="1"
                                    OnContent=""
                                    OffContent=""
                                    MinWidth="0"
                                    Toggled="Step3CapsuleToggle_Toggled"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Right: live preview widget -->
                    <Border
                        x:Name="Step3PreviewHost"
                        Grid.Column="1"
                        Width="220"
                        Height="200"
                        CornerRadius="10"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Padding="0"
                        VerticalAlignment="Center">
                        <Border.Background>
                            <SolidColorBrush x:Name="Step3PreviewBackground" Color="{ThemeResource SystemFillColorSolidNeutralBackground}"/>
                        </Border.Background>
                        <Grid>
                            <!-- Title bar -->
                            <Grid Height="32" VerticalAlignment="Top" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="10,0">
                                    <Border x:Name="Step3PreviewIcon" Width="14" Height="14" CornerRadius="3" Background="{ThemeResource AccentFillColorDefaultBrush}"/>
                                    <TextBlock x:Name="Step3PreviewTitle" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Text="My Files"/>
                                </StackPanel>
                            </Grid>
                            <!-- File list -->
                            <StackPanel Margin="10,38,10,10" Spacing="6">
                                <Border x:Name="Step3PreviewItem1" Padding="8,5" CornerRadius="4" Background="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0.85">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE8A5;" FontSize="10" Foreground="White"/>
                                        <TextBlock FontSize="10" Foreground="White" Text="Document.docx"/>
                                    </StackPanel>
                                </Border>
                                <Border Padding="8,5" CornerRadius="4" Background="{ThemeResource SubtleFillColorTertiaryBrush}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE7C3;" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Image.png"/>
                                    </StackPanel>
                                </Border>
                                <Border Padding="8,5" CornerRadius="4" Background="{ThemeResource SubtleFillColorTertiaryBrush}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE71B;" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Link (shortcut)"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ─────────── Step 4: Daily Use (hotkey + startup + storage) ─────────── -->
                <StackPanel
                    x:Name="Step4Panel"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="18"
                    MaxWidth="560">

                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource StepEyebrowText}" HorizontalAlignment="Center" svc:Localized.Key="Onboarding.Step4.Eyebrow"/>
                        <TextBlock Style="{StaticResource StepTitleText}" HorizontalAlignment="Center" TextAlignment="Center" svc:Localized.Key="Onboarding.Step4.Title"/>
                        <TextBlock Style="{StaticResource StepBodyText}" HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="460" svc:Localized.Key="Onboarding.Step4.Body"/>
                    </StackPanel>

                    <!-- Keycap visualization -->
                    <Grid x:Name="Step4KeycapHost" HorizontalAlignment="Center" Margin="0,2,0,6">
                        <Border
                            x:Name="Step4Keycap"
                            MinWidth="88"
                            Height="52"
                            Padding="16,0"
                            CornerRadius="8"
                            BorderThickness="1.5"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                <FontIcon x:Name="Step4KeycapIcon" Glyph="&#xE765;" FontSize="11" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="Step4KeycapText" FontSize="16" FontWeight="Bold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" HorizontalAlignment="Center" Text="F7"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Show/Hide hotkey card -->
                    <Border Style="{StaticResource SettingCard}" MaxWidth="500">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="3">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE765;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" svc:Localized.Key="Onboarding.Step4.HotkeyTitle"/>
                                </StackPanel>
                                <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" svc:Localized.Key="Onboarding.Step4.HotkeyDescription"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" Grid.Column="1" VerticalAlignment="Center">
                                <Button
                                    x:Name="Step4HotkeyChangeButton"
                                    MinWidth="72"
                                    Height="32"
                                    Padding="10,0"
                                    Click="Step4HotkeyChange_Click"
                                    FontSize="12"/>
                                <ToggleSwitch
                                    x:Name="Step4HotkeyToggle"
                                    OnContent=""
                                    OffContent=""
                                    MinWidth="0"
                                    Toggled="Step4HotkeyToggle_Toggled"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Search hotkey card -->
                    <Border Style="{StaticResource SettingCard}" MaxWidth="500">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="3">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE721;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" svc:Localized.Key="Onboarding.Step4.SearchHotkeyTitle"/>
                                </StackPanel>
                                <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" svc:Localized.Key="Onboarding.Step4.SearchHotkeyDescription"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock
                                    x:Name="Step4SearchHotkeyText"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                    VerticalAlignment="Center"
                                    Text="Alt+D"/>
                                <ToggleSwitch
                                    x:Name="Step4SearchHotkeyToggle"
                                    OnContent=""
                                    OffContent=""
                                    MinWidth="0"
                                    Toggled="Step4SearchHotkeyToggle_Toggled"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Startup toggle card -->
                    <Border Style="{StaticResource SettingCard}" MaxWidth="500">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="3">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE7F4;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" svc:Localized.Key="Onboarding.Step4.StartupTitle"/>
                                </StackPanel>
                                <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" svc:Localized.Key="Onboarding.Step4.StartupDescription"/>
                            </StackPanel>
                            <ToggleSwitch
                                x:Name="Step4StartupToggle"
                                Grid.Column="1"
                                OnContent=""
                                OffContent=""
                                MinWidth="0"
                                Toggled="Step4StartupToggle_Toggled"/>
                        </Grid>
                    </Border>

                    <!-- Storage path (secondary) -->
                    <Border Style="{StaticResource SettingCard}" MaxWidth="500" Padding="14,12">
                        <StackPanel Spacing="8">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE8B7;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock FontSize="12.5" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" svc:Localized.Key="Onboarding.Step4.StorageTitle"/>
                                    <TextBlock
                                        x:Name="Step4PathText"
                                        FontSize="11.5"
                                        FontFamily="Consolas"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Button
                                    x:Name="Step4ChangePathButton"
                                    Grid.Column="2"
                                    MinWidth="72"
                                    Height="28"
                                    Padding="8,0"
                                    FontSize="11.5"
                                    Click="Step4ChangePath_Click"
                                    svc:Localized.Key="Onboarding.Storage.ChangePath"/>
                            </Grid>
                            <TextBlock FontSize="11.5" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" svc:Localized.Key="Onboarding.Step4.StorageBody"/>
                            <!-- Pin to Quick Access -->
                            <Grid ColumnSpacing="10" Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" svc:Localized.Key="Onboarding.Step4.PinTitle"/>
                                <ToggleSwitch
                                    x:Name="Step4PinToggle"
                                    Grid.Column="1"
                                    OnContent=""
                                    OffContent=""
                                    MinWidth="0"
                                    Toggled="Step4PinToggle_Toggled"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ─────────── Step 5: Ready (summary + try-it animation) ─────────── -->
                <StackPanel
                    x:Name="Step5Panel"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="20"
                    MaxWidth="580">

                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource StepEyebrowText}" HorizontalAlignment="Center" svc:Localized.Key="Onboarding.Step5.Eyebrow"/>
                        <TextBlock Style="{StaticResource StepTitleText}" HorizontalAlignment="Center" TextAlignment="Center" svc:Localized.Key="Onboarding.Step5.Title"/>
                        <TextBlock Style="{StaticResource StepBodyText}" HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="460" svc:Localized.Key="Onboarding.Step5.Body"/>
                    </StackPanel>

                    <!-- Summary cards -->
                    <Grid x:Name="Step5SummaryGrid" ColumnSpacing="10" RowSpacing="10" MaxWidth="520" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingCard}" Padding="14,10">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE713;" FontSize="11" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                    <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" svc:Localized.Key="Onboarding.Step5.SummaryWidgets"/>
                                </StackPanel>
                                <TextBlock x:Name="Step5WidgetsSummary" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingCard}" Padding="14,10">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE7F4;" FontSize="11" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                    <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" svc:Localized.Key="Onboarding.Step5.SummaryAppearance"/>
                                </StackPanel>
                                <TextBlock x:Name="Step5AppearanceSummary" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SettingCard}" Padding="14,10">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE765;" FontSize="11" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                    <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" svc:Localized.Key="Onboarding.Step5.SummaryDaily"/>
                                </StackPanel>
                                <TextBlock x:Name="Step5DailySummary" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingCard}" Padding="14,10">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="11" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                    <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" svc:Localized.Key="Onboarding.Step5.SummaryStorage"/>
                                </StackPanel>
                                <TextBlock x:Name="Step5StorageSummary" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Try-it search animation -->
                    <Border x:Name="Step5SearchDemo" Style="{StaticResource SettingCard}" MaxWidth="420" Padding="16,14">
                        <StackPanel Spacing="10">
                            <!-- Simulated search box -->
                            <Border
                                x:Name="Step5SearchBox"
                                Height="36"
                                CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                Padding="12,0">
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE721;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,8,0"/>
                                    <TextBlock
                                        x:Name="Step5SearchDemoText"
                                        Grid.Column="1"
                                        FontSize="13"
                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                        VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <!-- Simulated results -->
                            <StackPanel x:Name="Step5SearchResults" Spacing="6" Opacity="0">
                                <Border Padding="10,7" CornerRadius="6" Background="{ThemeResource SubtleFillColorTertiaryBrush}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8A5;" FontSize="12" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Text="周报.docx"/>
                                    </StackPanel>
                                </Border>
                                <Border Padding="10,7" CornerRadius="6" Background="{ThemeResource SubtleFillColorTertiaryBrush}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE7C3;" FontSize="12" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Text="周报模板.xlsx"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <TextBlock FontSize="11.5" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" svc:Localized.Key="Onboarding.Step5.TrySearchHint"/>
                        </StackPanel>
                    </Border>

                    <!-- Hints -->
                    <StackPanel Spacing="6" MaxWidth="500">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE73E;" Style="{StaticResource HintIcon}"/>
                            <TextBlock Style="{StaticResource HintText}" svc:Localized.Key="Onboarding.Step5.Hint1"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE73E;" Style="{StaticResource HintIcon}"/>
                            <TextBlock Style="{StaticResource HintText}" svc:Localized.Key="Onboarding.Step5.Hint2"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

            </Grid>
        </ScrollViewer>

        <!-- ═════════════ Footer Navigation ═════════════ -->
        <Grid
            x:Name="FooterNav"
            Grid.Row="2"
            Opacity="1"
            Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel
                x:Name="ProgressDots"
                Grid.Column="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8"/>

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    x:Name="SkipButton"
                    MinWidth="88"
                    Click="SkipButton_Click"
                    svc:Localized.Key="Onboarding.Skip"/>
                <Button
                    x:Name="BackButton"
                    MinWidth="88"
                    Click="BackButton_Click"
                    svc:Localized.Key="Onboarding.Back"/>
                <Button
                    x:Name="NextButton"
                    MinWidth="96"
                    Click="NextButton_Click"
                    Style="{ThemeResource AccentButtonStyle}"
                    svc:Localized.Key="Onboarding.Next"/>
            </StackPanel>
        </Grid>

        <!-- ═════════════ Intro Overlay ═════════════ -->
        <Grid
            x:Name="IntroOverlay"
            Grid.RowSpan="3"
            Margin="-40"
            Padding="40"
            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
            IsHitTestVisible="False">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="18">
                <Canvas
                    x:Name="IntroMarkHost"
                    Width="170"
                    Height="170"
                    HorizontalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5"/>
                <StackPanel Spacing="8">
                    <TextBlock
                        x:Name="IntroTitleText"
                        HorizontalAlignment="Center"
                        FontSize="32"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        TextAlignment="Center"
                        svc:Localized.Key="Onboarding.Intro.Title"/>
                    <TextBlock
                        x:Name="IntroBodyText"
                        Width="420"
                        FontSize="15"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        LineHeight="24"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords"
                        svc:Localized.Key="Onboarding.Intro.Body"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
